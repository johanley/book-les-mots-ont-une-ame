%!PS

% The body of the book. The cover is a separate PDF.

% Ghostscript command:
%   C:\ghostscript\gs10.04.0\bin\gswin64c.exe -dNOSAFER -sDEVICE=pdfwrite -o BOOK.PDF BOOK.PS

(using.ps) run
(base.ps) using
(debug.ps) using
(fonts.ps) using
(strings.ps) using % string.ps is specific to the CP-1252 encoding.
(table.ps) using
(text-align.ps) using

% int 
% arg is the number of times /showpage has been called: 0, 1,...
% See /BeginPage of setpagedevice below.
%
% Sets the asymmetric work-box (sensitive to the page parity): translate to origin, wd, ht.
% Emit page numbers and the book's title.
% Moves the currentpoint to the top left of the work-box.
/start-new-page {
  [/idx] {
    (Starting new page...) here
    /page-num idx 3 sub def
    % WARNING: there are two hard-coded transition points for the page numbers
    page-num 1 ge  page-num 178 le and {
      % show page numbers and title
      % set the work-box; asymmetry in x, to avoid the spine 
      bleed  MARGIN-X  add  SPINE-AVOIDANCE page-num 2 mod 0 eq {neg} if add 
      bleed  MARGIN-Y  add
      translate % to the bottom left of the work-box
      
      % first show the page number
      (regular) 90 use-font
      /GAP ht 5 pct def
      small-caps-font
      /page-num-str page-num 4 string cvs def
      page-num 2 mod 0 eq {
        % left-hand page
        0 ht moveto 
        0 GAP rmoveto 
        page-num-str show
      } {
        % right-hand page
        wd ht moveto 
        0 GAP rmoveto 
        page-num-str show-right-align
      } ifelse
      % now show the text
      wd 50 pct  ht GAP add  moveto 
      page-num 168 le {TITLE}{INDEX-TITLE}ifelse str-upper-case show-ctr-x
      (regular) 100 use-font
    } {
      % no page numbers appear, and the centering is a bit different
      % set the work-box using only the trimmed page, with no margins
      bleed  bleed  translate % to the bottom left of the work-box
    }
    ifelse
    
    0 ht moveto % the top-left of the work-box, as a default currentposition
    % 0 0 wd ht rectstroke % to see the work-box
  } def-tmp
} bind def

% ax ay str 
% Show text centered horizontally at the currentpoint, using /ashow to adjust letter spacing by ax, ay.
/ashow-ctr-x {
  dup text-dim pop % ax ay text dx
  -2 div % ax ay text -dx/2
  0 rmoveto % ax ay text
  ashow
} bind def

% dict
% The dict has author, title, and body (usually an array).
% Show a quotation, but first test to see if a new page is needed.
% The policy is that quotations are never split by a page-break.
/show-quotation-on-1-page {
  dup 
  quotation-fits-on-page? not {
    NEW-PAGE
  } if
  show-quotation
  NEW-LINE % between rendered quotes
  NEW-LINE 
} bind def

% dict
% The dict has author, title, and body (usually an array).
/quotation-fits-on-page? {
  % use the null device, with a gsave-grestore.
  % no marks are made on the page using this technique
  gsave 
    % save-program-state (in case show-quotation ever changes program-state data)
    nulldevice % this uses the default CTM
    currentpoint exch pop /y0 defi
    show-quotation
    currentpoint exch pop /y1 defi
    y1 y0 sub % dy (corresponding to the author/title line); negative!
    % restore-program-state
  grestore
  currentpoint exch pop % dy y 
  add 0 ge 
} bind def

% dict
% The dict has author, title, and body (usually an array).
/show-quotation {
  3 dict begin
    {def} forall
    body type /arraytype eq{
      show-body-prose
    } {
      show-body-poetry
    } ifelse
    show-author-title
  end
} bind def

% Cycle through an array containing strings and control-codes. 
% The control codes can only set the font.
% Set the currentpoint to the start of the next line, to prepare for the author-title line.
/show-body-prose {
  % ragged-right, using the 1/2 word size trick to reduce jaggedness.
  % use stringwidth, not probe-ahead, to test each word, one at a time.
  % call new-line, but leave new-page to the caller.
  body {
    dup 
    type /nametype eq {
      cvx exec
    } {
      str-words {
        /word defi
        word str-width /word-wd defi
        /new-x currentpoint pop word-wd add def
        /line-overflow new-x wd sub def
        line-overflow  word-wd 2 div  gt { NEW-LINE } if
        word SPACE str-concat show
      } forall
    } ifelse
  } forall 
  NEW-LINE
} bind def

% Show lines of text having hard-coded line breaks, as in poetry.
% The /body is a single string, with \n-style newlines (such that the whole poem is 1 line of source data).
% No control codes are used in this style, and only the regular font is used.
% Set the currentpoint to the start of the next line, to prepare for the author-title line.
/show-body-poetry {
  % lines of fixed length, and only regular font
  (regular) 100 use-font
  body str-lines {
    show % one line at a time
    NEW-LINE % might cause a new page
  } forall % lines
} bind def

% str
% Return true iff the trimmed string has a length > 0
/is-present? {
  str-trim length 0 gt
} bind def

% THIS IS ALREADY IN STRING.PS.
% str
% Return the dx of the string (assumes dy is 0).
/str-width { stringwidth pop } bind def

% Show the author and/or title.
% Must fit on a single line.
% The author and title can be an empty string, but not both at the same time.
% The caller puts the currentpoint at the start of the line, after the quote body has finished.
% Assumes the author/title data is trimmed of empty spaces.
/show-author-title {
  % measure the width first, in order to find the starting point for /show
  % be careful with the comma in between: three cases: a+comma+space+t, a, t
  /size 90 def
  (regular) size use-font
  /width-all 
    DASH str-width 
    small-caps-font
    author str-upper-case str-width add
    (italic) size use-font
    title str-width add 
  def
  author is-present? title is-present? and {
    (regular) size use-font
    /width-all  width-all COMMA-SPACE str-width  add  def
  } if
  wd width-all sub  0  rmoveto
  
  (regular) size use-font
  DASH show
  author is-present? {
    small-caps-font
    author str-upper-case show
  } if
  author is-present? title is-present? and {
    (regular) size use-font
    COMMA-SPACE show
  } if
  title is-present? {
    (italic) size use-font
    title show 
  } if
  % let's not put a new line here yet; 
  % we need to interrogate the y-position at this point, for page breaks
} bind def


% THIS SHOULD USE A TEMP DICT
% str (filename)
/process-quotes-file-one-line-at-a-time {
  % open the file read-only; its encoding should be 8859-1.
  (r) file /quotes-file defi 
  /buffer MAX-QUOTE-LENGTH string def
  {
    quotes-file buffer readline {
      cvx % the string is scanned and interpreted according to PostScript rules
      exec % to transform the executable string into a dict, and put it on the stack
      show-quotation-on-1-page 
    } {
      % all quotes end the same way: with a newline, and never with an end-of-file
      % THE FILE TERMINATES WITH AN UNUSED LINE, that has no newline at its end.
      %pop 
      ==
      exit
    } ifelse
  } loop
  % the loop will automatically close the file once end-of-file has been reached.
  % this is just being extra-careful
  quotes-file status {
    (CLOSING THE OPEN FILE.) == 
    quotes-file closefile
  } {
    (OK: THE FILE WAS CLOSED.) ==
  } ifelse
} bind def

% dict
% The dict contains /author and (usually) /title.
% Example output:
%   DYLAN, BOB.......Shelter From The Storm
% The author is left-justified, the title is right-justified.
% The title can be absent, but that only happens when the 
% author has no other entries in the index.
/show-index-line {
  2 dict begin
    { def } forall
    /size 90 def
    (regular) size use-font
    small-caps-font
    author str-upper-case show
    title () ne {
      1 ex 0 rmoveto 
      (italic) size use-font
      /DOT (.) def
      {
        % emit dots, but stop when you near the title's x-position 
        currentpoint pop   wd title str-width sub 1 ex sub   ge { exit } if
        2 ex 0 DOT ashow % stretch out the spacing with /ashow
      } loop
      wd 
      currentpoint exch pop  % y
      moveto % the right side
      title show-right-align
    } if
    NEW-LINE
    currentpoint exch pop 0 le { NEW-PAGE } if
  end
} bind def

% THIS SHOULD USE A TEMP DICT
% str (filename)
/process-index-file-one-line-at-a-time {
  % open the file read-only; its encoding should be 8859-1.
  (r) file /index-file defi 
  /buffer MAX-QUOTE-LENGTH string def
  {
    index-file buffer readline {
      cvx % the string is scanned and interpreted according to PostScript rules
      exec % to transform the executable string into a dict, and put it on the stack
      show-index-line 
    } {
      % all entries end the same way: with a newline, and never with an end-of-file
      % THE FILE TERMINATES WITH AN UNUSED LINE, that has no newline at its end.
      %pop 
      ==
      exit
    } ifelse
  } loop
  % the loop will automatically close the file once end-of-file has been reached.
  % this is just being extra-careful
  index-file status {
    (CLOSING THE OPEN INDEX FILE.) == 
    index-file closefile
  } {
    (OK: THE INDEX FILE WAS CLOSED.) ==
  } ifelse
} bind def

% [[xy]]
% The caller will need to set the origin and scale to suitable values, using trial and error.
/draw-star-line {
  newpath
  /is-first? true def
  {
    aload pop % x y
    is-first? { moveto } {lineto } ifelse
    /is-first? false def
  } forall % points [x y]
  stroke
} bind def

% x y stellar-mag
% two circles at the given location
% first in the background color, then in the foreground with a smaller radius
% this will give a pleasing effect when drawing star-points after the star-lines
/draw-star-point {
  newpath
  [/x /y /stellar-mag] {
    /radius stellar-mag 2.5 gt {0.30} {0.45} ifelse  def
    1 setcolor
    x y radius 0 360 arc % to 'erase' star-lines a wee bit around the star
    fill
    0 setcolor
    x y radius 0.7 mul 0 360 arc
    fill
  } def-tmp
} bind def






% [{...}]  an array of procs
% THIS IS AN IMPORTANT PROC. IT APPLIES THE TYPESETTING INFORMATION.
% Each proc does some typesetting operation: managing the font and the currentpoint.
/TYPESET {
  { exec } forall
} bind def

% Regular font.
/R { (regular) 100 use-font } bind def

% Italic font.
/I { (italic) 100 use-font } bind def

% The current y-position.
/current-y {
  currentpoint exch pop % y
} bind def

% The current x-position.
/current-x {
  currentpoint pop % x
} bind def

% Move the currentpoint to the left, and down by the LEADING.
% Forces a NEW-PAGE if the new y-value is less than 0.
/NEW-LINE {
  current-y LEADING gt {
    0 
    current-y LEADING sub 
    moveto
  }
  { NEW-PAGE }
  ifelse 
} bind def

% Just calls showpage.
% See set-new-page, and /BeginPage of setpagedevice below.
/NEW-PAGE {
  showpage 
  % set-new-page will also be invoked
} bind def

% str (the title of the chapter).
% The caller might want to coerce the text to upper case.
% A new section of the book: chapter, short story.
% New page, with the title of the chapter.
% Moves the currentpoint about halfway down the page.
/NEW-CHAPTER {
  dup here
  NEW-PAGE
  wd 50 pct ht 70 pct moveto 
  (regular) 200 use-font  
  show-ctr-x % the title (the caller controls upper/lower case)
  0 ht 60 pct moveto % no indentation!
} bind def

% New-line, and indent a little bit.
/NEW-PARA {
  NEW-LINE
  2 INDENT
} bind def

% int
% Move to the right by the given multiple of em's.
/INDENT {
  em 0 rmoveto
} bind def

% Can force a NEW-PAGE.
/BLANK-LINE {
  current-y LEADING 2 mul gt {
    NEW-LINE NEW-LINE
  } 
  { NEW-PAGE } 
  ifelse 
} bind def

% str
% Regular text flow, using the current font.
% Can force a NEW-PAGE. 
/PROSE {
  [/str] {
    % chop the string into [str], an array of words, separating on whitespace
    str str-words {
      /word defi
      word str-width /word-wd defi
      /new-x current-x word-wd add def
      /line-overflow new-x wd sub def
      line-overflow  word-wd 2 div  gt { NEW-LINE } if
      word SPACE str-concat show
    } forall
  } def-tmp
} bind def

% [()] bool
% An array of strings; one string is one line of the stanza.
%
% The boolean is a flag for emitting the final new-line; this controls how the stanza interacts 
% with whatever FOLLOWS; use FALSE if followed by another stanza, TRUE if followed by a paragraph.
% That will manage the single blank line after the stanza.
% 
% A stanza of poetry, kept-together on one page.
% ASSUMES: the lines aren't too long for the page width.
% ASSUMES: there's 2..8 lines of poetry, such that it can reasonably be kept-together on one page.
% The lines are rendered in the current font.
/STANZA {
  [/lines /include-last-new-line] {
    % compute the final y-value, to see if it will fit on the current page
    % y - (num-lines + 1) * leading > 0
    current-y  lines length 1 add   LEADING mul  sub 
    0 gt { 
      BLANK-LINE
    } { 
      NEW-PAGE % initial blank line not needed
    }
    ifelse 
    0 1 lines length 2 sub {
      % all except the last line; there must be at least 2 lines!
      /idx defi
      3 INDENT 
      lines idx get show NEW-LINE
    } for
    % the last line gets special treatment because of the yes-no for the final newline
    3 INDENT 
    lines last show 
    include-last-new-line {NEW-LINE} if
 } def-tmp
} bind def

% str
% Start of a section of a chapter. 
% Some chapters have parts 'I', 'II', and so on.
% centered, short-enough text; a blank line before and after the text.
% ASSUMES: the following part starts with a single new-line (like a new paragraph.)
/SECTION {
  % compute the final y-value, to see if it will fit on the current page
  current-y 3 LEADING mul sub
  0 gt {
    BLANK-LINE
  } {
    NEW-PAGE % initial blank line not needed
  } ifelse
  show-ctr-x 
  NEW-LINE % because the following part is assumed to start with 1 more new-line (a paragraph).
} bind def

% [()] () [()] - intro-lines, body, outro-lines
% Uses the current font.
% The intro-lines are on the left, the outro-lines are on the right.
% The intro-outro lines will fit on the line.
% BE CAREFUL WITH PAGE BREAKS.
% The body uses only the current font.
/CORRESPONDANCE {
  [/intro /body /outro]{
    % temp alterations to the work-box; manual restore later
    wd 10 pct 0 translate
    /wd wd 80 pct def % this is in a temp dict
    BLANK-LINE
    intro {
      3 INDENT show NEW-LINE 
    } forall
    NEW-LINE
    body PROSE 
    BLANK-LINE
    outro {
      25 INDENT show NEW-LINE 
    } forall
    wd -10 pct 0 translate % back to where it was
    NEW-LINE % because the next para has a new-line too
  } def-tmp
} bind def

/inch {72 mul} bind def
/8th-inch {72 mul 8 div} bind def

%%BeginSetup    
   % 'US Trade' is 6" x 9". This is called the 'trim' size.
   %   'trim': the dimensions after trimming off the 'bleed'.
   %   'bleed': margin around all sides that gets cut off (trimmed); 1/8" is typical.
   %   'safety': margin around all sides in which text should not appear. 1/8" is typical.
  /trim-width 6 inch def 
  /trim-height 9 inch def 
  /bleed 1 8th-inch def 
  /page-width  trim-width bleed 2 mul add  def 
  /page-height  trim-height bleed 2 mul add  def 
  /ASPECT-RATIO trim-height trim-width div def % > 1.0 in this project
  
  /MARGIN-X 7 8th-inch def 
  /MARGIN-Y 6 8th-inch def 
  % wd and ht are for the work-box for the main content (pages with page numbers).
  /wd trim-width MARGIN-X 2 mul sub def   
  /ht trim-height MARGIN-Y 2 mul sub def   
  /SPINE-AVOIDANCE 1.5 8th-inch def
  
  <<
    /PageSize [page-width  page-height]
    /BeginPage {start-new-page}  
  >> setpagedevice  
  << /NeverEmbed [ ] >> setdistillerparams  % always embed fonts
  true setstrokeadjust  % minimizes off-by-one-pixel line issues

  %C:\Users\Owner\AppData\Local\Microsoft\Windows\Fonts
  /MyRegular /ACaslonPro-Regular windowize % windows-1252 encoding vector
  /MyItalic /ACaslonPro-Italic windowize 
  
  << 
    (regular) /MyRegular
    (italic) /MyItalic
  >>
  11 % default font size 
  init-my-fonts
  
  % My model: "Jerusalem" by Simon Montefiore (Knopf, 2011)
  /LEADING 1.2 11 mul def % this is a common leading, 120% of the type size
  
  /TITLE (Les Mots Ont Une Âme) def
  /AUTHOR (Guy de Maupassant) def
  /DATE (2026) def
  /SPACE ( ) def
  /DASH (~ ) def
  /COMMA-SPACE (, ) def
  %/QUOTES-FILE (quotes-data-8859-1/quotes_flat_file_ps.txt) def
  %/INDEX-FILE (quotes-data-8859-1/index_file_ps.txt) def
  %/MAX-QUOTE-LENGTH 5000 def 
  %/INDEX-TITLE (Authors and Titles) def
%%EndSetup 

  % small title 
  (regular) 130 use-font  
  trim-width 45 pct 
  trim-height 80 pct moveto 
  3 0 TITLE str-upper-case ashow-ctr-x

  % font details, link to github 
  (regular) 100 use-font
  trim-width 50 pct 
  trim-height 15 pct moveto 
  (Adobe Caslon Pro 11 \(leading 13.2\)) show-ctr-x

  (italic) 100 use-font
  trim-width 50 pct 
  trim-height 10 pct moveto 
  (github.com/johanley/book-les-mots-ont-une-ame) show-ctr-x

showpage

  % blank page 
  
showpage

  % large title and drawing
  (regular) 230 use-font  
  trim-width 45 pct trim-height 85 pct moveto 
  0.3 em 0 (Les Mots) str-upper-case ashow-ctr-x
  trim-width 45 pct trim-height 75 pct moveto 
  0.3 em 0 (Ont Une Âme) str-upper-case ashow-ctr-x
  
  % a drawing of a constellation
  gsave 
    % put the origin near the center of the drawing
    trim-width 50 pct
    trim-height 46 pct  
    translate 

    % manually tweak the scale  
    4.5 dup scale  
    0.2 setlinewidth

    % draw a well-known constellation, as simple lines and dots  
    % no labels are used here, just the basic shape
    (constellation/orion.ps) run
  grestore

  (regular) 125 use-font  
  trim-width 50 pct trim-height 15 pct moveto 
  AUTHOR show-ctr-x
  trim-width 50 pct trim-height 10 pct moveto 
  DATE show-ctr-x

showpage

  % blank page

showpage

  %QUOTES-FILE
  %process-quotes-file-one-line-at-a-time 
  
