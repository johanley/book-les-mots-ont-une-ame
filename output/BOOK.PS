%!PS

% The body of the book. The cover is a separate PDF.

% Ghostscript command:
%   C:\ghostscript\gs10.04.0\bin\gswin64c.exe -dNOSAFER -sDEVICE=pdfwrite -o BOOK.PDF BOOK.PS

(using.ps) run
(base.ps) using
(debug.ps) using
(fonts.ps) using
(strings.ps) using % string.ps is specific to the CP-1252 encoding.
(table.ps) using
(text-align.ps) using

% int 
% arg is the number of times /showpage has been called: 0, 1,...
% See /BeginPage of setpagedevice below.
%
% Sets the asymmetric work-box (sensitive to the page parity): translate to origin, wd, ht.
% Emit page numbers and the book's title.
% Moves the currentpoint to the top left of the work-box.
/start-new-page {
  (Starting new page...) here
  3 sub /page-num defi % in user dict; lives long, gets overwritten
  
  % set the work-box; asymmetry in x, to avoid the spine 
  bleed  MARGIN-X  add  SPINE-AVOIDANCE page-num 2 mod 0 eq {neg} if add 
  bleed  MARGIN-Y  add
  translate % the origin to the bottom left of the work-box
  
  2 dict begin
    % WARNING: hard-coded page numbers
    page-num 1 ge  page-num 123 le  and {
      % show page numbers and title
      % first show the page number
      (regular) 90 use-font
      /GAP ht 5 pct def
      small-caps-font
      /page-num-str page-num 4 string cvs def
      page-num 2 mod 0 eq {
        % left-hand page
        0 ht moveto 
        0 GAP rmoveto 
        page-num-str show
      } {
        % right-hand page
        wd ht moveto 
        0 GAP rmoveto 
        page-num-str show-right-align
      } ifelse
      % now show the chapter's title at the top of the page
      wd 50 pct  ht GAP add  moveto 
      CURRENT-CHAPTER-TITLE str-upper-case show-ctr-x
      (regular) 100 use-font
    } 
    if
    
    0 ht moveto % the top-left of the work-box, as a default currentposition
    %0 0 wd ht rectstroke % to see the work-box
  end
} bind def

% ax ay str 
% Show text centered horizontally at the currentpoint, using /ashow to adjust letter spacing by ax, ay.
/ashow-ctr-x {
  dup text-dim pop % ax ay text dx
  -2 div % ax ay text -dx/2
  0 rmoveto % ax ay text
  ashow
} bind def

% dict
% The dict has author, title, and body (usually an array).
% Show a quotation, but first test to see if a new page is needed.
% The policy is that quotations are never split by a page-break.
/show-quotation-on-1-page {
  dup 
  quotation-fits-on-page? not {
    NEW-PAGE
  } if
  show-quotation
  NEW-LINE % between rendered quotes
  NEW-LINE 
} bind def

% dict
% The dict has author, title, and body (usually an array).
/quotation-fits-on-page? {
  % use the null device, with a gsave-grestore.
  % no marks are made on the page using this technique
  gsave 
    % save-program-state (in case show-quotation ever changes program-state data)
    nulldevice % this uses the default CTM
    currentpoint exch pop /y0 defi
    show-quotation
    currentpoint exch pop /y1 defi
    y1 y0 sub % dy (corresponding to the author/title line); negative!
    % restore-program-state
  grestore
  currentpoint exch pop % dy y 
  add 0 ge 
} bind def

% dict
% The dict has author, title, and body (usually an array).
/show-quotation {
  3 dict begin
    {def} forall
    body type /arraytype eq{
      show-body-prose
    } {
      show-body-poetry
    } ifelse
    show-author-title
  end
} bind def

% Cycle through an array containing strings and control-codes. 
% The control codes can only set the font.
% Set the currentpoint to the start of the next line, to prepare for the author-title line.
/show-body-prose {
  % ragged-right, using the 1/2 word size trick to reduce jaggedness.
  % use stringwidth, not probe-ahead, to test each word, one at a time.
  % call new-line, but leave new-page to the caller.
  body {
    dup 
    type /nametype eq {
      cvx exec
    } {
      str-words {
        /word defi
        word str-width /word-wd defi
        /new-x currentpoint pop word-wd add def
        /line-overflow new-x wd sub def
        line-overflow  word-wd 2 div  gt { NEW-LINE } if
        word SPACE str-concat show
      } forall
    } ifelse
  } forall 
  NEW-LINE
} bind def

% Show lines of text having hard-coded line breaks, as in poetry.
% The /body is a single string, with \n-style newlines (such that the whole poem is 1 line of source data).
% No control codes are used in this style, and only the regular font is used.
% Set the currentpoint to the start of the next line, to prepare for the author-title line.
/show-body-poetry {
  % lines of fixed length, and only regular font
  (regular) 100 use-font
  body str-lines {
    show % one line at a time
    NEW-LINE % might cause a new page
  } forall % lines
} bind def

% str
% Return true iff the trimmed string has a length > 0
/is-present? {
  str-trim length 0 gt
} bind def

% THIS IS ALREADY IN STRING.PS.
% str
% Return the dx of the string (assumes dy is 0).
/str-width { stringwidth pop } bind def

% Show the author and/or title.
% Must fit on a single line.
% The author and title can be an empty string, but not both at the same time.
% The caller puts the currentpoint at the start of the line, after the quote body has finished.
% Assumes the author/title data is trimmed of empty spaces.
/show-author-title {
  % measure the width first, in order to find the starting point for /show
  % be careful with the comma in between: three cases: a+comma+space+t, a, t
  /size 90 def
  (regular) size use-font
  /width-all 
    DASH str-width 
    small-caps-font
    author str-upper-case str-width add
    (italic) size use-font
    title str-width add 
  def
  author is-present? title is-present? and {
    (regular) size use-font
    /width-all  width-all COMMA-SPACE str-width  add  def
  } if
  wd width-all sub  0  rmoveto
  
  (regular) size use-font
  DASH show
  author is-present? {
    small-caps-font
    author str-upper-case show
  } if
  author is-present? title is-present? and {
    (regular) size use-font
    COMMA-SPACE show
  } if
  title is-present? {
    (italic) size use-font
    title show 
  } if
  % let's not put a new line here yet; 
  % we need to interrogate the y-position at this point, for page breaks
} bind def


% THIS SHOULD USE A TEMP DICT
% str (filename)
/process-quotes-file-one-line-at-a-time {
  % open the file read-only; its encoding should be 8859-1.
  (r) file /quotes-file defi 
  /buffer MAX-QUOTE-LENGTH string def
  {
    quotes-file buffer readline {
      cvx % the string is scanned and interpreted according to PostScript rules
      exec % to transform the executable string into a dict, and put it on the stack
      show-quotation-on-1-page 
    } {
      % all quotes end the same way: with a newline, and never with an end-of-file
      % THE FILE TERMINATES WITH AN UNUSED LINE, that has no newline at its end.
      %pop 
      ==
      exit
    } ifelse
  } loop
  % the loop will automatically close the file once end-of-file has been reached.
  % this is just being extra-careful
  quotes-file status {
    (CLOSING THE OPEN FILE.) == 
    quotes-file closefile
  } {
    (OK: THE FILE WAS CLOSED.) ==
  } ifelse
} bind def

% dict
% The dict contains /author and (usually) /title.
% Example output:
%   DYLAN, BOB.......Shelter From The Storm
% The author is left-justified, the title is right-justified.
% The title can be absent, but that only happens when the 
% author has no other entries in the index.
/show-index-line {
  2 dict begin
    { def } forall
    /size 90 def
    (regular) size use-font
    small-caps-font
    author str-upper-case show
    title () ne {
      1 ex 0 rmoveto 
      (italic) size use-font
      /DOT (.) def
      {
        % emit dots, but stop when you near the title's x-position 
        currentpoint pop   wd title str-width sub 1 ex sub   ge { exit } if
        2 ex 0 DOT ashow % stretch out the spacing with /ashow
      } loop
      wd 
      currentpoint exch pop  % y
      moveto % the right side
      title show-right-align
    } if
    NEW-LINE
    currentpoint exch pop 0 le { NEW-PAGE } if
  end
} bind def

% THIS SHOULD USE A TEMP DICT
% str (filename)
/process-index-file-one-line-at-a-time {
  % open the file read-only; its encoding should be 8859-1.
  (r) file /index-file defi 
  /buffer MAX-QUOTE-LENGTH string def
  {
    index-file buffer readline {
      cvx % the string is scanned and interpreted according to PostScript rules
      exec % to transform the executable string into a dict, and put it on the stack
      show-index-line 
    } {
      % all entries end the same way: with a newline, and never with an end-of-file
      % THE FILE TERMINATES WITH AN UNUSED LINE, that has no newline at its end.
      %pop 
      ==
      exit
    } ifelse
  } loop
  % the loop will automatically close the file once end-of-file has been reached.
  % this is just being extra-careful
  index-file status {
    (CLOSING THE OPEN INDEX FILE.) == 
    index-file closefile
  } {
    (OK: THE INDEX FILE WAS CLOSED.) ==
  } ifelse
} bind def

% [[xy]]
% The caller will need to set the origin and scale to suitable values, using trial and error.
/draw-star-line {
  newpath
  /is-first? true def
  {
    aload pop % x y
    is-first? { moveto } {lineto } ifelse
    /is-first? false def
  } forall % points [x y]
  stroke
} bind def

% x y stellar-mag
% two circles at the given location
% first in the background color, then in the foreground with a smaller radius
% this will give a pleasing effect when drawing star-points after the star-lines
/draw-star-point {
  newpath
  [/x /y /stellar-mag] {
    /radius stellar-mag 2.5 gt {0.30} {0.45} ifelse  def
    1 setcolor
    x y radius 0 360 arc % to 'erase' star-lines a wee bit around the star
    fill
    0 setcolor
    x y radius 0.7 mul 0 360 arc
    fill
  } def-tmp
} bind def






% [{...}]  an array of procs
% THIS IS AN IMPORTANT PROC. IT APPLIES THE TYPESETTING INFORMATION.
% Each proc does some typesetting operation: managing the font and the currentpoint.
/TYPESET {
  { exec } forall
} bind def

% Regular font.
/R { (regular) 100 use-font } bind def

% Italic font.
/I { (italic) 100 use-font } bind def

% The current y-position.
/current-y {
  currentpoint exch pop % y
} bind def

% The current x-position.
/current-x {
  currentpoint pop % x
} bind def

% Move the currentpoint to the left, and down by the LEADING.
% Forces a NEW-PAGE if the new y-value is less than 0.
/NEW-LINE {
  current-y LEADING gt {
    0 
    current-y LEADING sub 
    moveto
  }
  { NEW-PAGE }
  ifelse 
} bind def

% Just calls showpage.
% See set-new-page, and /BeginPage of setpagedevice below.
/NEW-PAGE {
  showpage 
  % set-new-page will also be invoked
} bind def

% str (the title of the chapter).
% This implementation coerces text to upper case.
% A new section of the book: chapter, short story.
% New page, with the title of the chapter.
% Moves the currentpoint about halfway down the page.
/NEW-CHAPTER {
  /CURRENT-CHAPTER-TITLE defi % visible to the NEW-PAGE proc (userdict)
  CURRENT-CHAPTER-TITLE here % log it to stdout
  NEW-PAGE
  wd 50 pct ht 80 pct moveto 
  (regular) 150 use-font  
  CURRENT-CHAPTER-TITLE str-upper-case show-ctr-x 
  0 ht 70 pct moveto % no indentation!
  % append to the TOC array
  TABLE-OF-CONTENTS <</chapter-title CURRENT-CHAPTER-TITLE /start-page page-num >> append-to-array  % [] left on stack
  /TABLE-OF-CONTENTS defi % redefined
} bind def

% New-line, and indent a little bit.
/NEW-PARA {
  NEW-LINE
  2 INDENT
} bind def

% int
% Move to the right by the given multiple of em's.
/INDENT {
  em 0 rmoveto
} bind def

% Two more new-lines.
% Can force a NEW-PAGE.
/BLANK-LINE {
  current-y LEADING 2 mul gt {
    NEW-LINE 
    NEW-LINE
  } 
  { NEW-PAGE } 
  ifelse 
} bind def

% str
% Regular text flow, using the current font.
% Emits each word found in the string with a trailing space.
% An initial or final trailing space is emitted only if str starts or ends with a space.
% Can force a NEW-LINE/NEW-PAGE.
/PROSE {
  [/str] {
    str SPACE str-starts-with? {SPACE show} if
    str str-words /words defi % chop into words (all spaces are obliterated)
    0 1  words length 1 sub {
      /idx defi
      words idx get  /word defi
      word str-width  /word-wd defi
      current-x word-wd add  /new-x defi
      new-x wd sub  /line-overflow defi
      line-overflow  word-wd 2 div  gt { NEW-LINE } if
      word show 
      idx  words length 1 sub  lt {
        SPACE show % add a space after all non-terminal words
      } if
    } for
    str SPACE str-ends-with? {SPACE show} if
    % % chop the string into [str], an array of words, separating on whitespace
    % str str-words {
      % /word defi
      % word str-width /word-wd defi
      % /new-x current-x word-wd add def
      % /line-overflow new-x wd sub def
      % line-overflow  word-wd 2 div  gt { NEW-LINE } if
      % word SPACE str-concat show % always emit each word with a trailing whitespace!
    % } forall
  } def-tmp
} bind def

% [()] bool
% An array of strings; one string is one line of the stanza.
%
% The boolean is a flag for emitting the final new-line; this controls how the stanza interacts 
% with whatever FOLLOWS; use FALSE if followed by another stanza, TRUE if followed by a paragraph.
% That will manage the single blank line after the stanza.
% 
% A stanza of poetry, kept-together on one page.
% ASSUMES: the lines aren't too long for the page width.
% ASSUMES: there's 2..8 lines of poetry, such that it can reasonably be kept-together on one page.
% The lines are rendered in the current font.
/STANZA {
  [/lines /include-last-new-line] {
    %(regular) 95 use-font
    I
    % compute the final y-value, to see if it will fit on the current page
    % y - (num-lines + 1) * leading > 0
    current-y  lines length 1 add   LEADING mul  sub 
    0 gt { 
      NEW-LINE % should already have one NL preceding
    } { 
      NEW-PAGE % initial blank line not needed
    }
    ifelse 
    0 1 lines length 2 sub {
      % all except the last line; there must be at least 2 lines!
      /idx defi
      3 INDENT 
      lines idx get show 
      NEW-LINE
    } for
    % the last line gets special treatment because of the yes-no for the final newline
    3 INDENT 
    lines last show 
    NEW-LINE
    include-last-new-line {NEW-PARA} if
 } def-tmp
} bind def

% str
% Start of a section of a chapter. 
% Some chapters have parts 'I', 'II', and so on.
% centered, short-enough text; a blank line before and after the text; regular font.
% ASSUMES: the following part starts with a single new-line (like a new paragraph.)
/SECTION {
  R
  %(regular) 120 use-font 
  % compute the final y-value, to see if it will fit on the current page
  current-y 2 LEADING mul sub
  0 lt {
    NEW-PAGE 
  } if
  wd 50 pct 0 rmoveto
  show-ctr-x 
  NEW-LINE % because the following part is assumed to start with 1 more new-line (a paragraph).
} bind def

% [()] () [()] - intro-lines, body, outro-lines
% Uses the current font.
% The intro-lines are on the left, the outro-lines are on the right.
% The intro-outro lines will fit on the line.
% BE CAREFUL WITH PAGE BREAKS.
% The body uses only the current font.
/CORRESPONDANCE {
  [/intro /body /outro]{
    % temp alterations to the work-box; manual restore later
    wd 10 pct 0 translate
    /wd wd 80 pct def % this is in a temp dict
    NEW-LINE % there should already be one NL in place
    intro {
      3 INDENT show NEW-LINE 
    } forall
    NEW-LINE
    body PROSE 
    BLANK-LINE
    outro {
      25 INDENT show NEW-LINE 
    } forall
    wd -10 pct 0 translate % back to where it was
    NEW-LINE % because the next para has a new-line too
  } def-tmp
} bind def

% Show the table of contents at the END of the book.
/SHOW-TABLE-OF-CONTENTS {
  NEW-PAGE
  (regular) 100 use-font 
  wd 50 pct ht 85 pct moveto
  TABLE-OF-CONTENTS-HEADING show-ctr-x 
  NEW-LINE 
  NEW-LINE 
  % [ <</chapter-title (Le Lit) /start-page>> ] cycle over the array.
  % left align the text, right-align the page numbers
  % the text is padded with dots .... until it reaches a certain length (found by mere experiment)
  TABLE-OF-CONTENTS {
    % << /chapter-title (Le Lit) /start-page 42 >>
    /chap defi % dict
    wd 15 pct current-y moveto
    chap /chapter-title get show
    { ( .) show
      current-x  wd 78 pct  gt { exit } if
    } loop
    wd 85 pct current-y moveto
    chap /start-page get 4 string cvs show-right-align
    NEW-LINE
  } forall
  
  % font details, link to github 
  wd 50 pct 
  ht 15 pct moveto 
  (Adobe Caslon Pro 11 \(leading 13.2\)) show-ctr-x

  (italic) 100 use-font
  wd 50 pct 
  ht 10 pct moveto 
  (github.com/johanley/book-les-mots-ont-une-ame) show-ctr-x
  
} bind def

% []
% Show the items in the array on stdout.
/list-array {
 { == } forall
} bind def


/inch {72 mul} bind def
/8th-inch {72 mul 8 div} bind def

%%BeginSetup    
   % 'US Trade' is 6" x 9". This is called the 'trim' size.
   %   'trim': the dimensions after trimming off the 'bleed'.
   %   'bleed': margin around all sides that gets cut off (trimmed); 1/8" is typical.
   %   'safety': margin around all sides in which text should not appear. 1/8" is typical.
  /trim-width 6 inch def 
  /trim-height 9 inch def 
  /bleed 1 8th-inch def 
  /page-width  trim-width bleed 2 mul add  def 
  /page-height  trim-height bleed 2 mul add  def 
  /ASPECT-RATIO trim-height trim-width div def % > 1.0 in this project
  
  /MARGIN-X 7 8th-inch def 
  /MARGIN-Y 6 8th-inch def 
  % wd and ht are for the work-box for the main content (pages with page numbers).
  /wd trim-width MARGIN-X 2 mul sub def   
  /ht trim-height MARGIN-Y 2 mul sub def   
  /SPINE-AVOIDANCE 1.5 8th-inch def

  /TABLE-OF-CONTENTS-HEADING (TABLE DES MATIÈRES) def
  /TABLE-OF-CONTENTS [] def % at runtime append a small dict for each chapter: <</chapter-title (L'Enfant) /start-page 53>>
  
  <<
    /PageSize [page-width  page-height]
    /BeginPage {start-new-page}  
  >> setpagedevice  
  << /NeverEmbed [ ] >> setdistillerparams  % always embed fonts
  true setstrokeadjust  % minimizes off-by-one-pixel line issues

  %C:\Users\Owner\AppData\Local\Microsoft\Windows\Fonts
  /MyRegular /ACaslonPro-Regular windowize % windows-1252 encoding vector
  /MyItalic /ACaslonPro-Italic windowize 
  
  << 
    (regular) /MyRegular
    (italic) /MyItalic
  >>
  11 % default font size 
  init-my-fonts
  
  % My model: "Jerusalem" by Simon Montefiore (Knopf, 2011)
  /LEADING 1.2 11 mul def % this is a common leading, 120% of the type size
  
  /TITLE (Les Mots Ont Une Âme) def
  /AUTHOR (Guy de Maupassant) def
  /DATE (2026) def
  /SPACE ( ) def
  /DASH (~ ) def
  /COMMA-SPACE (, ) def
  %/QUOTES-FILE (quotes-data-8859-1/quotes_flat_file_ps.txt) def
  %/INDEX-FILE (quotes-data-8859-1/index_file_ps.txt) def
  %/MAX-QUOTE-LENGTH 5000 def 
  %/INDEX-TITLE (Authors and Titles) def
%%EndSetup 

  % small title 
  (regular) 130 use-font  
  wd 41 pct 
  ht 80 pct moveto 
  3 0 TITLE str-upper-case ashow-ctr-x

showpage

  % blank page 
  
showpage

  % large title and drawing
  (regular) 230 use-font  
  wd 42 pct ht 85 pct moveto 
  0.3 em 0 (Les Mots) str-upper-case ashow-ctr-x
  wd 42 pct ht 75 pct moveto 
  0.3 em 0 (Ont Une Âme) str-upper-case ashow-ctr-x
  
  % a drawing of a constellation
  gsave 
    % put the origin near the center of the drawing
    wd 50 pct
    ht 46 pct  
    translate 

    % manually tweak the scale  
    4.5 dup scale  
    0.2 setlinewidth

    % draw a well-known constellation, as simple lines and dots  
    % no labels are used here, just the basic shape
    (constellation/orion.ps) run
  grestore

  (regular) 125 use-font  
  wd 50 pct ht 15 pct moveto 
  AUTHOR show-ctr-x
  %wd 50 pct ht 10 pct moveto 
  %DATE show-ctr-x

showpage


[
 { (La Rempailleuse) NEW-CHAPTER } 
 { R (C’était à la fin du dîner d’ouverture de chasse chez le marquis de Bertrans. Onze chasseurs, huit jeunes femmes et le médecin du pays étaient assis autour de la grande table illuminée, couverte de fruits et de fleurs. ) PROSE } 
 { NEW-PARA } 
 { R (On vint à parler d’amour, et une grande discussion s’éleva, l’éternelle discussion, pour savoir si on pouvait aimer vraiment une fois ou plusieurs fois. On cita des exemples de gens n’ayant jamais eu qu’un amour sérieux; on cita aussi d’autres exemples de gens ayant aimé souvent, avec violence. Les hommes, en général, prétendaient que la passion, comme les maladies, peut frapper plusieurs fois le même être, et le frapper à le tuer si quelque obstacle se dresse devant lui. Bien que cette manière de voir ne fût pas contestable, les femmes, dont l’opinion s’appuyait sur la poésie bien plus que sur l’observation, affirmaient que l’amour, l’amour vrai, le grand amour, ne pouvait tomber qu’une fois sur un mortel, qu’il était semblable à la foudre, cet amour, et qu’un cœur touché par lui demeurait ensuite tellement vidé, ravagé, incendié, qu’aucun autre sentiment puissant, même aucun rêve, n’y pouvait germer de nouveau. ) PROSE } 
 { NEW-PARA } 
 { R (Le marquis ayant aimé beaucoup, combattait vivement cette croyance: ) PROSE } 
 { NEW-PARA } 
 { R (— Je vous dis, moi, qu’on peut aimer plusieurs fois avec toutes ses forces et toute son âme. Vous me citez des gens qui se sont tués par amour, comme preuve de l’impossibilité d’une seconde passion. Je vous répondrai que, s’ils n’avaient pas commis cette bêtise de se suicider, ce qui leur enlevait toute chance de rechute, ils se seraient guéris; et ils auraient recommencé, et toujours, jusqu’à leur mort naturelle. Il en est des amoureux comme des ivrognes. Qui a bu boira — qui a aimé aimera. C’est une affaire de tempérament, cela. ) PROSE } 
 { NEW-PARA } 
 { R (On prit pour arbitre le docteur, vieux médecin parisien retiré aux champs, et on le pria de donner son avis. ) PROSE } 
 { NEW-PARA } 
 { R (Justement il n’en avait pas: ) PROSE } 
 { NEW-PARA } 
 { R (— Comme l’a dit le marquis, c’est une affaire de tempérament; quant à moi, j’ai eu connaissance d’une passion qui dura cinquante-cinq ans, sans un jour de répit, et qui ne se termina que par la mort. ) PROSE } 
 { NEW-PARA } 
 { R (La marquise battit des mains. ) PROSE } 
 { NEW-PARA } 
 { R (— Est-ce beau cela! Et quel rêve d’être aimé ainsi! Quel bonheur de vivre cinquante-cinq ans tout enveloppé de cette affection acharnée et pénétrante! Comme il a dû être heureux et bénir la vie celui qu’on adora de la sorte! ) PROSE } 
 { NEW-PARA } 
 { R (Le médecin sourit: ) PROSE } 
 { NEW-PARA } 
 { R (— En effet, madame, vous ne vous trompez pas sur ce point, que l’être aimé fut un homme. Vous le connaissez, c’est M. Chouquet, le pharmacien du bourg. Quant à elle, la femme, vous l’avez connue aussi, c’est la vieille rempailleuse de chaises qui venait tous les ans au château. Mais je vais me faire mieux comprendre. ) PROSE } 
 { NEW-PARA } 
 { R (L’enthousiasme des femmes était tombé, et leur visage dégoûté disait: «Pouah!» comme si l’amour n’eût dû frapper que des êtres fins et distingués, seuls dignes de l’intérêt des gens comme il faut. ) PROSE } 
 { NEW-PARA } 
 { NEW-PARA } 
 { R (Le médecin reprit: ) PROSE } 
 { NEW-PARA } 
 { R (— J’ai été appelé, il y a trois mois, auprès de cette vieille femme, à son lit de mort. Elle était arrivée, la veille, dans la voiture qui lui servait de maison, traînée par la rosse que vous avez vue, et accompagnée de ses deux grands chiens noirs, ses amis et ses gardiens. Le curé était déjà là. Elle nous fit ses exécuteurs testamentaires, et, pour nous dévoiler le sens de ses volontés dernières, elle nous raconta toute sa vie. Je ne sais rien de plus singulier et de plus poignant. ) PROSE } 
 { NEW-PARA } 
 { R (Son père était rempailleur et sa mère rempailleuse. Elle n’a jamais eu de logis planté en terre. ) PROSE } 
 { NEW-PARA } 
 { R (Toute petite, elle errait, haillonneuse, vermineuse, sordide. On s’arrêtait à l’entrée des villages, le long des fossés; on dételait la voiture; le cheval broutait; le chien dormait, le museau sur ses pattes; et la petite se roulait dans l’herbe pendant que le père et la mère rafistolaient, à l’ombre des ormes du chemin, tous les vieux sièges de la commune. On ne parlait guère, dans cette demeure ambulante. Après les quelques mots nécessaires pour décider qui ferait le tour des maisons en poussant le cri bien connu : «Remmmpailleur de chaises!» on se mettait à tortiller la paille, face à face ou côte à côte. Quand l’enfant allait trop loin ou tentait d’entrer en relation avec quelque galopin du village, la voix colère du père la rappelait : «Veux-tu bien revenir ici, crapule!» C’étaient les seuls mots de tendresse qu’elle entendait. ) PROSE } 
 { NEW-PARA } 
 { R (Quand elle devint plus grande, on l’envoya faire la récolte des fonds de sièges avariés. Alors elle ébaucha quelques connaissances de place en place avec les gamins; mais c’étaient alors les parents de ses nouveaux amis qui rappelaient brutalement leurs enfants : «Veux-tu bien venir ici, polisson! Que je te voie causer avec les va-nu-pieds!…» ) PROSE } 
 { NEW-PARA } 
 { R (Souvent les petits gars lui jetaient des pierres. ) PROSE } 
 { NEW-PARA } 
 { R (Des dames lui ayant donné quelques sous, elle les garda soigneusement. ) PROSE } 
 { NEW-PARA } 
 { NEW-PARA } 
 { R (Un jour — elle avait alors onze ans — comme elle passait par ce pays, elle rencontra derrière le cimetière le petit Chouquet qui pleurait parce qu’un camarade lui avait volé deux liards. Ces larmes d’un petit bourgeois, d’un de ces petits qu’elle s’imaginait, dans sa frêle caboche de déshéritée, être toujours contents et joyeux, la bouleversèrent. Elle s’approcha, et, quand elle connut la raison de sa peine, elle versa entre ses mains toutes ses économies, sept sous, qu’il prit naturellement, en essuyant ses larmes. Alors, folle de joie, elle eut l’audace de l’embrasser. Comme il considérait attentivement sa monnaie, il se laissa faire. Ne se voyant ni repoussée, ni battue, elle recommença; elle l’embrassa à pleins bras, à plein cœur. Puis elle se sauva. ) PROSE } 
 { NEW-PARA } 
 { R (Que se passa-t-il dans cette misérable tête? S’est-elle attachée à ce mioche parce qu’elle lui avait sacrifié sa fortune de vagabonde, ou parce qu’elle lui avait donné son premier baiser tendre? Le mystère est le même pour les petits que pour les grands. ) PROSE } 
 { NEW-PARA } 
 { R (Pendant des mois, elle rêva de ce coin de cimetière et de ce gamin. Dans l’espérance de le revoir, elle vola ses parents, grappillant un sou par-ci, un sou par-là, sur un rempaillage, ou sur les provisions qu’elle allait acheter. ) PROSE } 
 { NEW-PARA } 
 { R (Quand elle revint, elle avait deux francs dans sa poche, mais elle ne put qu’apercevoir le petit pharmacien, bien propre, derrière les carreaux de la boutique paternelle, entre un bocal rouge et un ténia. ) PROSE } 
 { NEW-PARA } 
 { R (Elle ne l’en aima que davantage, séduite, émue, extasiée par cette gloire de l’eau colorée, cette apothéose des cristaux luisants. ) PROSE } 
 { NEW-PARA } 
 { R (Elle garda en elle son souvenir ineffaçable, et, quand elle le rencontra, l’an suivant, derrière l’école, jouant aux billes avec ses camarades, elle se jeta sur lui, le saisit dans ses bras, et le baisa avec tant de violence qu’il se mit à hurler de peur. Alors, pour l’apaiser, elle lui donna son argent : trois francs vingt, un vrai trésor, qu’il regardait avec des yeux agrandis. ) PROSE } 
 { NEW-PARA } 
 { R (Il le prit et se laissa caresser tant qu’elle voulut. ) PROSE } 
 { NEW-PARA } 
 { R (Pendant quatre ans encore, elle versa entre ses mains toutes ses réserves, qu’il empochait avec conscience en échange de baisers consentis. Ce fut une fois trente sous, une fois deux francs, une fois douze sous seulement (elle en pleura de peine et d’humiliation, mais l’année avait été mauvaise) et la dernière fois, cinq francs, une grosse pièce ronde, qui le fit rire d’un rire content. ) PROSE } 
 { NEW-PARA } 
 { R (Elle ne pensait plus qu’à lui; et il attendait son retour avec une certaine impatience, courait au-devant d’elle en la voyant, ce qui faisait bondir le cœur de la fillette. ) PROSE } 
 { NEW-PARA } 
 { R (Puis il disparut. On l’avait mis au collège. Elle le sut en interrogeant habilement. Alors elle usa d’une diplomatie infinie pour changer l’itinéraire de ses parents et les faire passer par ici au moment des vacances. Elle y réussit, mais après un an de ruses. Elle était donc restée deux ans sans le revoir; et elle le reconnut à peine, tant il était changé, grandi, embelli, imposant dans sa tunique à boutons d’or. Il feignit de ne pas la voir et passa fièrement près d’elle. ) PROSE } 
 { NEW-PARA } 
 { R (Elle en pleura pendant deux jours; et depuis lors elle souffrit sans fin. ) PROSE } 
 { NEW-PARA } 
 { R (Tous les ans elle revenait; passait devant lui sans oser le saluer et sans qu’il daignât même tourner les yeux vers elle. Elle l’aimait éperdument. Elle me dit : « C’est le seul homme que j’aie vu sur la terre, monsieur le médecin; je ne sais pas si les autres existaient seulement.» ) PROSE } 
 { NEW-PARA } 
 { R (Ses parents moururent. Elle continua leur métier, mais elle prit deux chiens au lieu d’un, deux terribles chiens qu’on n’aurait pas osé braver. ) PROSE } 
 { NEW-PARA } 
 { R (Un jour, en rentrant dans ce village où son cœur était resté, elle aperçut une jeune femme qui sortait de la boutique Chouquet au bras de son bien-aimé. C’était sa femme. Il était marié. ) PROSE } 
 { NEW-PARA } 
 { R (Le soir même, elle se jeta dans la mare qui est sur la place de la Mairie. Un ivrogne attardé la repêcha, et la porta à la pharmacie. Le fils Chouquet descendit en robe de chambre, pour la soigner, et, sans paraître la reconnaître, la déshabilla, la frictionna, puis il lui dit d’une voix dure : «Mais vous êtes folle! Il ne faut pas être bête comme ça!» ) PROSE } 
 { NEW-PARA } 
 { R (Cela suffit pour la guérir. Il lui avait parlé! Elle était heureuse pour longtemps. ) PROSE } 
 { NEW-PARA } 
 { R (Il ne voulut rien recevoir en rémunération de ses soins, bien qu’elle insistât vivement pour le payer. ) PROSE } 
 { NEW-PARA } 
 { R (Et toute sa vie s’écoula ainsi. Elle rempaillait en songeant à Chouquet. Tous les ans, elle l’apercevait derrière ses vitraux. Elle prit l’habitude d’acheter chez lui des provisions de menus médicaments. De la sorte elle le voyait de près, et lui parlait, et lui donnait encore de l’argent. ) PROSE } 
 { NEW-PARA } 
 { R (Comme je vous l’ai dit en commençant, elle est morte ce printemps. Après m’avoir raconté toute cette triste histoire, elle me pria de remettre à celui qu’elle avait si patiemment aimé toutes les économies de son existence, car elle n’avait travaillé que pour lui, rien que pour lui, disait-elle, jeûnant même pour mettre de côté, et être sûre qu’il penserait à elle, au moins une fois, quand elle serait morte. ) PROSE } 
 { NEW-PARA } 
 { R (Elle me donna donc deux mille trois cent vingt-sept francs. Je laissai à M. le curé les vingt-sept francs pour l’enterrement, et j’emportai le reste quand elle eut rendu le dernier soupir. ) PROSE } 
 { NEW-PARA } 
 { R (Le lendemain, je me rendis chez les Chouquet. Ils achevaient de déjeuner, en face l’un de l’autre, gros et rouges, fleurant les produits pharmaceutiques, importants et satisfaits. ) PROSE } 
 { NEW-PARA } 
 { R (On me fit asseoir; on m’offrit un kirsch, que j’acceptai; et je commençai mon discours d’une voix émue, persuadé qu’ils allaient pleurer. ) PROSE } 
 { NEW-PARA } 
 { R (Dès qu’il eut compris qu’il avait été aimé de cette vagabonde, de cette rempailleuse, de cette rouleuse, Chouquet bondit d’indignation, comme si elle lui avait volé sa réputation, l’estime des honnêtes gens, son honneur intime, quelque chose de délicat qui lui était plus cher que la vie. ) PROSE } 
 { NEW-PARA } 
 { R (Sa femme, aussi exaspérée que lui, répétait : «Cette gueuse! cette gueuse! cette gueuse!…» sans pouvoir trouver autre chose. ) PROSE } 
 { NEW-PARA } 
 { R (Il s’était levé; il marchait à grands pas derrière la table, le bonnet grec chaviré sur une oreille. Il balbutiait : «Comprend-on ça, docteur ? Voilà de ces choses horribles pour un homme! Que faire? Oh! si je l’avais su de son vivant, je l’aurais fait arrêter par la gendarmerie et flanquer en prison. Et elle n’en serait pas sortie, je vous en réponds!» ) PROSE } 
 { NEW-PARA } 
 { R (Je demeurais stupéfait du résultat de ma démarche pieuse. Je ne savais que dire ni que faire. Mais j’avais à compléter ma mission. Je repris : «Elle m’a chargé de vous remettre ses économies, qui montent à deux mille trois cents francs. Comme ce que je viens de vous apprendre semble vous être fort désagréable, le mieux serait peut-être de donner cet argent aux pauvres.» ) PROSE } 
 { NEW-PARA } 
 { R (Ils me regardaient, l’homme et la femme, perclus de saisissement. ) PROSE } 
 { NEW-PARA } 
 { R (Je tirai l’argent de ma poche, du misérable argent de tous les pays et de toutes les marques, de l’or et des sous mêlés. Puis je demandai : «Que décidez-vous?» ) PROSE } 
 { NEW-PARA } 
 { R (Mme Chouquet parla la première : «Mais, puisque c’était sa dernière volonté, à cette femme… il me semble qu’il nous est bien difficile de refuser.» ) PROSE } 
 { NEW-PARA } 
 { R (Le mari, vaguement confus, reprit : «Nous pourrions toujours acheter avec ça quelque chose pour nos enfants.» ) PROSE } 
 { NEW-PARA } 
 { R (Je dis d’un air sec : «Comme vous voudrez.» ) PROSE } 
 { NEW-PARA } 
 { R (Il reprit : «Donnez toujours, puisqu’elle vous en a chargé; nous trouverons bien moyen de l’employer à quelque bonne œuvre.» ) PROSE } 
 { NEW-PARA } 
 { R (Je remis l’argent, je saluai, et je partis. ) PROSE } 
 { NEW-PARA } 
 { NEW-PARA } 
 { R (Le lendemain Chouquet vint me trouver et, brusquement : «Mais elle a laissé ici sa voiture, cette… cette femme. Qu’est-ce que vous en faites, de cette voiture? ) PROSE } 
 { NEW-PARA } 
 { R (— «Rien, prenez-la si vous voulez. ) PROSE } 
 { NEW-PARA } 
 { R (— «Parfait; cela me va; j’en ferai une cabane pour mon potager.» ) PROSE } 
 { NEW-PARA } 
 { R (Il s’en allait. Je le rappelai. «Elle a laissé aussi son vieux cheval et ses deux chiens. Les voulez-vous?» Il s’arrêta, surpris: «Ah! non, par exemple; que voulez-vous que j’en fasse? Disposez-en comme vous voudrez.» Et il riait. Puis il me tendit sa main que je serrai. Que voulez-vous? Il ne faut pas, dans un pays, que le médecin et le pharmacien soient ennemis. ) PROSE } 
 { NEW-PARA } 
 { R (J’ai gardé les chiens chez moi. Le curé, qui a une grande cour, a pris le cheval. La voiture sert de cabane à Chouquet; et il a acheté cinq obligations de chemin de fer avec l’argent. ) PROSE } 
 { NEW-PARA } 
 { R (Voilà le seul amour profond que j’aie rencontré, dans ma vie.» ) PROSE } 
 { NEW-PARA } 
 { R (Le médecin se tut. ) PROSE } 
 { NEW-PARA } 
 { R (Alors la marquise, qui avait des larmes dans les yeux, soupira : «Décidément, il n’y a que les femmes pour savoir aimer!» ) PROSE } 
] TYPESET

[
 { (L’Infirme) NEW-CHAPTER } 
 { R (Cette aventure m’est arrivée vers 1882. Je venais de m’installer dans le coin d’un wagon vide, et j’avais refermé la portière avec l’espérance de rester seul, quand elle se rouvrit brusquement, et j’entendis une voix qui disait: ) PROSE } 
 { NEW-PARA } 
 { R (— Prenez garde, monsieur, nous nous trouvons juste au croisement des lignes; le marchepied est très haut. ) PROSE } 
 { NEW-PARA } 
 { R (Une autre voix répondit: ) PROSE } 
 { NEW-PARA } 
 { R (— Ne crains rien, Laurent, je vais prendre les poignées. ) PROSE } 
 { NEW-PARA } 
 { R (Puis une tête apparut coiffée d’un chapeau rond, et deux mains, s’accrochant aux lanières de cuir et de drap suspendues des deux côtés de la portière, hissèrent lentement un gros corps, dont les pieds firent sur le marchepied un bruit de canne frappant le sol. ) PROSE } 
 { NEW-PARA } 
 { R (Or, quand l’homme eut fait entrer son torse dans le compartiment, je vis apparaître dans l’étoffe flasque du pantalon, le bout peint en noir d’une jambe de bois, qu’un autre pilon pareil suivit bientôt. ) PROSE } 
 { NEW-PARA } 
 { R (Une tête se montra derrière ce voyageur et demanda: ) PROSE } 
 { NEW-PARA } 
 { R (— Vous êtes bien, monsieur? ) PROSE } 
 { NEW-PARA } 
 { R (— Oui, mon garçon. ) PROSE } 
 { NEW-PARA } 
 { R (— Alors, voilà vos paquets et vos béquilles. ) PROSE } 
 { NEW-PARA } 
 { R (Et un domestique, qui avait l’air d’un vieux soldat, monta à son tour, portant en ses bras un tas de choses, enveloppées en des papiers noirs et jaunes, ficelées soigneusement, et les déposa, l’une après l’autre, dans le filet au-dessus de la tête de son maître. Puis il dit: ) PROSE } 
 { NEW-PARA } 
 { R (— Voilà, monsieur, c’est tout. Il y en a cinq: les bonbons, la poupée, le tambour, le fusil et le pâté de foies gras. ) PROSE } 
 { NEW-PARA } 
 { R (— C’est bien, mon garçon. ) PROSE } 
 { NEW-PARA } 
 { R (— Bon voyage, monsieur. ) PROSE } 
 { NEW-PARA } 
 { R (— Merci, Laurent; bonne santé! ) PROSE } 
 { NEW-PARA } 
 { R (L’homme s’en alla en repoussant la porte, et je regardai mon voisin. ) PROSE } 
 { NEW-PARA } 
 { R (Il pouvait avoir trente-cinq ans, bien que ses cheveux fussent presque blancs; il était décoré, moustachu, fort gros, atteint de cette obésité poussive des hommes actifs et forts qu’une infirmité tient immobiles. ) PROSE } 
 { NEW-PARA } 
 { R (Il s’essuya le front, souffla, et me regardant bien en face: ) PROSE } 
 { NEW-PARA } 
 { R (— La fumée vous gêne-t-elle, monsieur? ) PROSE } 
 { NEW-PARA } 
 { R (— Non, monsieur. ) PROSE } 
 { NEW-PARA } 
 { R (Cet œil, cette voix, ce visage, je les connaissais. Mais d’où, de quand ? Certes, j’avais rencontré ce garçon-là, je lui avais parlé, je lui avais serré la main. Cela datait de loin, de très loin; c’était perdu dans cette brume où l’esprit semble chercher à tâtons les souvenirs et les poursuit, comme des fantômes fuyants, sans les saisir. ) PROSE } 
 { NEW-PARA } 
 { R (Lui aussi, maintenant, me dévisageait avec la ténacité et la fixité d’un homme qui se rappelle un peu, mais pas tout à fait. ) PROSE } 
 { NEW-PARA } 
 { R (Nos yeux, gênés de ce contact obstiné des regards, se détournèrent;  puis, au bout de quelques secondes, attirés de nouveau par la volonté obscure et tenace de la mémoire en travail, ils se rencontrèrent encore, et je dis: ) PROSE } 
 { NEW-PARA } 
 { R (— Mon Dieu, monsieur, au lieu de nous observer à la dérobée pendant une heure, ne vaudrait-il pas mieux chercher ensemble où nous nous sommes connus? ) PROSE } 
 { NEW-PARA } 
 { R (Le voisin répondit avec bonne grâce: ) PROSE } 
 { NEW-PARA } 
 { R (— Vous avez tout à fait raison, monsieur. ) PROSE } 
 { NEW-PARA } 
 { R (Je me nommai: ) PROSE } 
 { NEW-PARA } 
 { R (— Je m’appelle Henry Bonclair, magistrat. ) PROSE } 
 { NEW-PARA } 
 { R (Il hésita quelques secondes; puis, avec ce vague de l’œil et de la voix qui accompagne les grandes tensions d’esprit: ) PROSE } 
 { NEW-PARA } 
 { R (—Ah! parfaitement, je vous ai rencontré chez les Poincel, autrefois, avant la guerre, voilà douze ans de cela! ) PROSE } 
 { NEW-PARA } 
 { R (— Oui, monsieur… Ah! ah!… vous êtes le lieutenant Revalière? ) PROSE } 
 { NEW-PARA } 
 { R (— Oui… Je fus même le capitaine Revalière jusqu’au jour où j’ai perdu mes pieds… tous les deux d’un seul coup, sur le passage d’un boulet. ) PROSE } 
 { NEW-PARA } 
 { R (Et nous nous regardâmes de nouveau, maintenant que nous nous connaissions. ) PROSE } 
 { NEW-PARA } 
 { R (Je me rappelais parfaitement avoir vu ce beau garçon mince qui conduisait les cotillons avec une furie agile et gracieuse et qu’on avait surnommé, je crois, «la Trombe». Mais derrière cette image, nettement évoquée, flottait encore quelque chose d’insaisissable, une histoire que j’avais sue et oubliée, une de ces histoires auxquelles on prête une attention bienveillante et courte, et qui ne laissent dans l’esprit qu’une marque presque imperceptible. ) PROSE } 
 { NEW-PARA } 
 { R (Il y avait de l’amour là-dedans. J’en retrouvais la sensation particulière au fond de ma mémoire, mais rien de plus, sensation comparable au fumet que sème pour le nez d’un chien le pied d’un gibier sur le sol. ) PROSE } 
 { NEW-PARA } 
 { R (Peu à peu, cependant, les ombres s’éclaircirent et une figure de jeune fille surgit devant mes yeux. Puis son nom éclata dans ma tête comme un pétard qui s’allume : Mlle de Mandal. Je me rappelais tout, maintenant. C’était, en effet, une histoire d’amour, mais banale. Cette jeune fille aimait ce jeune homme, lorsque je l’avais rencontrée, et on parlait de leur prochain mariage. Il paraissait lui-même très épris, très heureux. ) PROSE } 
 { NEW-PARA } 
 { R (Je levai les yeux vers le filet où tous les paquets apportés par le domestique de mon voisin tremblotaient aux secousses du train, et la voix du serviteur me revint comme s’il finissait à peine de parler. ) PROSE } 
 { NEW-PARA } 
 { R (Il avait dit: ) PROSE } 
 { NEW-PARA } 
 { R (— Voilà, monsieur, c’est tout. Il y en a cinq: les bonbons, la poupée, le tambour, le fusil et le pâté de foies gras. ) PROSE } 
 { NEW-PARA } 
 { R (Alors, en une seconde, un roman se composa et se déroula dans ma tête. Il ressemblait d’ailleurs à tous ceux que j’avais lus où, tantôt le jeune homme, tantôt la jeune fille, épouse son fiancé ou sa fiancée après la catastrophe, soit corporelle, soit financière. Donc, cet officier mutilé pendant la guerre avait retrouvé, après la campagne, la jeune fille qui s’était promise à lui; et, tenant son engagement, elle s’était donnée. ) PROSE } 
 { NEW-PARA } 
 { R (Je jugeais cela beau, mais simple, comme on juge simples tous les dévouements et tous les dénouements des livres et du théâtre. Il semble toujours, quand on lit, ou quand on écoute, à ces écoles de magnanimité, qu’on se serait sacrifié soi-même avec un plaisir enthousiaste, avec un élan magnifique. Mais on est de fort mauvaise humeur, le lendemain, quand un ami misérable vient vous emprunter quelque argent. ) PROSE } 
 { NEW-PARA } 
 { R (Puis, soudain, une autre supposition, moins poétique et plus réaliste, se substitua à la première. Peut-être s’était-il marié avant la guerre, avant l’épouvantable accident de ce boulet lui coupant les jambes, et avait-elle dû, désolée et résignée, recevoir, soigner, consoler, soutenir ce mari, parti fort et beau, revenu avec les pieds fauchés, affreux débris voué à l’immobilité, aux colères impuissantes et à l’obésité fatale. ) PROSE } 
 { NEW-PARA } 
 { R (Était-il heureux ou torturé? Une envie, légère d’abord, puis grandissante, puis irrésistible, me saisit de connaître son histoire, d’en savoir au moins les points principaux, qui me permettraient de deviner ce qu’il ne pourrait pas ou ne voudrait pas me dire. ) PROSE } 
 { NEW-PARA } 
 { R (Je lui parlais, tout en songeant. Nous avions échangé quelques paroles banales; et moi, les yeux levés vers le filet, je pensais: «Il a donc trois enfants : les bonbons sont pour sa femme, la poupée  pour sa petite fille, le tambour et le fusil pour ses fils, ce pâté de foies gras pour lui.» ) PROSE } 
 { NEW-PARA } 
 { R (Soudain, je lui demandai: ) PROSE } 
 { NEW-PARA } 
 { R (— Vous êtes père, monsieur?  ) PROSE } 
 { NEW-PARA } 
 { R (Il répondit: ) PROSE } 
 { NEW-PARA } 
 { R (— Non, monsieur. ) PROSE } 
 { NEW-PARA } 
 { R (Je me sentis soudain confus comme si j’avais commis une grosse inconvenance et je repris: ) PROSE } 
 { NEW-PARA } 
 { R (— Je vous demande pardon. Je l’avais pensé en entendant votre domestique parler de jouets. On entend sans écouter, et on conclut malgré soi. ) PROSE } 
 { NEW-PARA } 
 { R (Il sourit, puis murmura: ) PROSE } 
 { NEW-PARA } 
 { R (— Non, je ne suis même pas marié. J’en suis resté aux préliminaires. ) PROSE } 
 { NEW-PARA } 
 { R (J’eus l’air de me souvenir tout à coup. ) PROSE } 
 { NEW-PARA } 
 { R (— Ah!… c’est vrai, vous étiez fiancé, quand je vous ai connu, fiancé avec Mlle de Mandal, je crois. ) PROSE } 
 { NEW-PARA } 
 { R (— Oui, monsieur, votre mémoire est excellente. ) PROSE } 
 { NEW-PARA } 
 { R (J’eus une audace excessive, et j’ajoutai: ) PROSE } 
 { NEW-PARA } 
 { R (— Oui, je crois me rappeler aussi avoir entendu dire que Mlle de Mandal avait épousé monsieur… monsieur… ) PROSE } 
 { NEW-PARA } 
 { R (Il prononça tranquillement ce nom. ) PROSE } 
 { NEW-PARA } 
 { R (— M. de Fleurel. ) PROSE } 
 { NEW-PARA } 
 { R (— Oui, c’est cela! Oui… je me rappelle même, à ce propos, avoir entendu parler de votre blessure. ) PROSE } 
 { NEW-PARA } 
 { R (Je le regardais bien en face; et il rougit. ) PROSE } 
 { NEW-PARA } 
 { R (Sa figure pleine, bouffie, que l’afflux constant de sang rendait déjà pourpre, se teinta davantage encore. ) PROSE } 
 { NEW-PARA } 
 { R (Il répondit avec vivacité, avec l’ardeur soudaine d’un homme qui plaide une cause perdue d’avance, perdue dans son esprit et dans son cœur, mais qu’il veut gagner devant l’opinion. ) PROSE } 
 { NEW-PARA } 
 { R (— On a tort, monsieur, de prononcer à côté du mien le nom de Mme de Fleurel. Quand je suis revenu de la guerre, sans mes pieds, hélas! je n’aurais jamais accepté, jamais, qu’elle devînt ma femme. Est-ce que c’était possible? Quand on se marie, monsieur, ce n’est pas pour faire parade de générosité: c’est pour vivre, tous les jours, toutes les heures, toutes les minutes, toutes les secondes, à côté d’un homme; et, si cet homme est difforme comme moi, on se condamne, en l’épousant, à une souffrance qui durera jusqu’à la mort! Oh! je comprends, j’admire tous les sacrifices, tous les dévouements, quand ils ont une limite, mais je n’admets pas le renoncement d’une femme à toute une vie qu’elle espère heureuse, à toutes les joies, à tous les rêves, pour satisfaire l’admiration de la galerie. Quand j’entends sur le plancher de ma chambre le battement de mes pilons et celui de mes béquilles, ce bruit de moulin que je fais à chaque pas, j’ai des exaspérations à étrangler mon serviteur. Croyez-vous qu’on puisse accepter d’une femme de tolérer ce qu’on ne supporte pas soi-même? Et puis, vous imaginez-vous que c’est joli, mes bouts de jambes?…» ) PROSE } 
 { NEW-PARA } 
 { R (Il se tut. Que lui dire? Je trouvais qu’il avait raison! Pouvais-je la blâmer, la mépriser, même lui donner tort, à elle? Non. Cependant? Le dénouement conforme à la règle, à la moyenne, à la vérité, à la vraisemblance, ne satisfaisait pas mon appétit poétique. Ces moignons héroïques appelaient un beau sacrifice qui me manquait, et j’en éprouvais une déception. ) PROSE } 
 { NEW-PARA } 
 { R (Je lui demandai tout à coup: ) PROSE } 
 { NEW-PARA } 
 { R (— Mme de Fleurel a des enfants? ) PROSE } 
 { NEW-PARA } 
 { R (— Oui, une fille et deux garçons. C’est pour eux que je porte ces jouets. Son mari et elle ont été très bons pour moi. ) PROSE } 
 { NEW-PARA } 
 { R (Le train montait la rampe de Saint-Germain. Il passa les tunnels, entra en gare, s’arrêta. ) PROSE } 
 { NEW-PARA } 
 { R (J’allais offrir mon bras pour aider la descente de l’officier mutilé quand deux mains se tendirent vers lui, par la portière ouverte: ) PROSE } 
 { NEW-PARA } 
 { R (— Bonjour! mon cher Revalière. ) PROSE } 
 { NEW-PARA } 
 { R (— Ah! bonjour, Fleurel. ) PROSE } 
 { NEW-PARA } 
 { R (Derrière l’homme, la femme souriait, radieuse, encore jolie, envoyant des «bonjour!» de ses doigts gantés. Une petite fille, à côté d’elle, sautillait de joie, et deux garçonnets regardaient avec des yeux avides le tambour et le fusil passant du filet du wagon entre les mains de leur père. ) PROSE } 
 { NEW-PARA } 
 { R (Quand l’infirme fut sur le quai, tous les enfants l’embrassèrent. Puis on se mit en route, et la fillette, par amitié, tenait dans sa petite main la traverse vernie d’une béquille, comme elle aurait pu tenir, en marchant à son côté, le pouce de son grand ami. ) PROSE } 
] TYPESET

[
 { (Mademoiselle Perle) NEW-CHAPTER } 
 { (I) SECTION } 
 { NEW-PARA } 
 { R (Quelle singulière idée j’ai eue, vraiment, ce soir-là, de choisir pour reine Mlle Perle. ) PROSE } 
 { NEW-PARA } 
 { R (Je vais tous les ans faire les Rois chez mon vieil ami Chantal. Mon père, dont il était le plus intime camarade, m’y conduisait quand j’étais enfant. J’ai continué, et je continuerai sans doute tant que je vivrai, et tant qu’il y aura un Chantal en ce monde. ) PROSE } 
 { NEW-PARA } 
 { R (Les Chantal, d’ailleurs, ont une existence singulière; ils vivent à Paris comme s’ils habitaient Grasse, Yvetot ou Pont-à-Mousson. ) PROSE } 
 { NEW-PARA } 
 { R (Ils possèdent, auprès de l’Observatoire, une maison dans un petit jardin. Ils sont chez eux, là, comme en province. De Paris, du vrai Paris, ils ne connaissent rien, ils ne soupçonnent rien; ils sont si loin, si loin! Parfois, cependant, ils y font un voyage, un long voyage. Mme Chantal va aux grandes provisions, comme on dit dans la famille. Voici comment on va aux grandes provisions. ) PROSE } 
 { NEW-PARA } 
 { R (Mlle Perle, qui a les clefs des armoires de cuisine (car les armoires au linge sont administrées par la maîtresse elle-même), Mlle Perle prévient que le sucre touche à sa fin, que les conserves sont épuisées, qu’il ne reste plus grand’chose au fond du sac à café. ) PROSE } 
 { NEW-PARA } 
 { R (Ainsi mise en garde contre la famine, Mme Chantal passe l’inspection des restes, en prenant des notes sur un calepin. Puis, quand elle a inscrit beaucoup de chiffres, elle se livre d’abord à de longs calculs et ensuite à de longues discussions avec Mlle Perle. On finit cependant par se mettre d’accord et par fixer les quantités de chaque chose dont on se pourvoira pour trois mois: sucre, riz, pruneaux, café, confitures, boîtes de petits pois, de haricots, de homard, poissons salés ou fumés, etc., etc. ) PROSE } 
 { NEW-PARA } 
 { R (Après quoi, on arrête le jour des achats et on s’en va, en fiacre, dans un fiacre à galerie, chez un épicier considérable qui habite au delà des ponts, dans les quartiers neufs. ) PROSE } 
 { NEW-PARA } 
 { R (Mme Chantal et Mlle Perle font ce voyage ensemble, mystérieusement, et reviennent à l’heure du dîner, exténuées, bien qu’émues encore, et cahotées dans le coupé, dont le toit est couvert de paquets et de sacs, comme une voiture de déménagement. ) PROSE } 
 { NEW-PARA } 
 { R (Pour les Chantal, toute la partie de Paris située de l’autre côté de la Seine constitue les quartiers neufs, quartiers habités par une population singulière, bruyante, peu honorable, qui passe les jours en dissipations, les nuits en fêtes, et qui jette l’argent par les fenêtres. De temps en temps cependant, on mène les jeunes filles au théâtre, à l’Opéra-Comique ou au Français, quand la pièce est recommandée par le journal que lit M. Chantal. ) PROSE } 
 { NEW-PARA } 
 { R (Les jeunes filles ont aujourd’hui dix-neuf et dix-sept ans; ce sont deux belles filles, grandes et fraîches, très bien élevées, trop bien élevées, si bien élevées qu’elles passent inaperçues comme deux jolies poupées. Jamais l’idée ne me viendrait de faire attention ou de faire la cour aux demoiselles Chantal; c’est à peine si on ose leur parler, tant on les sent immaculées; on a presque peur d’être inconvenant en les saluant. ) PROSE } 
 { NEW-PARA } 
 { R (Quant au père, c’est un charmant homme, très instruit, très ouvert, très cordial, mais qui aime avant tout le repos, le calme, la tranquillité, et qui a fortement contribué à momifier ainsi sa famille pour vivre à son gré, dans une stagnante immobilité. Il lit beaucoup, cause volontiers, et s’attendrit facilement. L’absence de contacts, de coudoiements et de heurts a rendu très sensible et délicat son épiderme, son épiderme moral. La moindre chose l’émeut, l’agite et le fait souffrir. ) PROSE } 
 { NEW-PARA } 
 { R (Les Chantal ont des relations cependant, mais des relations restreintes, choisies avec soin dans le voisinage. Ils échangent aussi deux ou trois visites par an avec des parents qui habitent au loin. ) PROSE } 
 { NEW-PARA } 
 { R (Quant à moi, je vais dîner chez eux le 15 août et le jour des Rois. Cela fait partie de mes devoirs comme la communion de Pâques pour les catholiques. ) PROSE } 
 { NEW-PARA } 
 { R (Le 15 août, on invite quelques amis, mais aux Rois, je suis le seul convive étranger. ) PROSE } 
 { NEW-PARA } 
 { NEW-PARA } 
 { (II) SECTION } 
 { NEW-PARA } 
 { R (Donc, cette année, comme les autres années, j’ai été dîner chez les Chantal pour fêter l’Épiphanie. ) PROSE } 
 { NEW-PARA } 
 { R (Selon la coutume, j’embrassai M. Chantal, Mme Chantal et Mlle Perle, et je fis un grand salut à Mlles Louise et Pauline. On m’interrogea sur mille choses, sur les événements du boulevard, sur la politique, sur ce qu’on pensait dans le public des affaires du Tonkin, et sur nos représentants. Mme Chantal, une grosse dame, dont toutes les idées me font l’effet d’être carrées à la façon des pierres de taille, avait coutume d’émettre cette phrase comme conclusion à toute discussion politique: «Tout cela est de la mauvaise graine pour plus tard.» Pourquoi me suis-je toujours imaginé que les idées de Mme Chantal sont carrées? Je n’en sais rien; mais tout ce qu’elle dit prend cette forme dans mon esprit: un carré, un gros carré avec quatre angles symétriques. Il y a d’autres personnes dont les idées me semblent toujours rondes et roulantes comme des cerceaux. Dès qu’elles ont commencé une phrase sur quelque chose, ça roule, ça va, ça sort par dix, vingt, cinquante idées rondes, des grandes et des petites que je vois courir l’une derrière l’autre, jusqu’au bout de l’horizon. D’autres personnes aussi ont des idées pointues… Enfin, cela importe peu. ) PROSE } 
 { NEW-PARA } 
 { R (On se mit à table comme toujours, et le dîner s’acheva sans qu’on eût dit rien à retenir. ) PROSE } 
 { NEW-PARA } 
 { R (Au dessert, on apporta le gâteau des Rois. Or, chaque année, M. Chantal était roi. Était-ce l’effet d’un hasard continu ou d’une convention familiale, je n’en sais rien, mais il trouvait infailliblement la fève dans sa part de pâtisserie, et il proclamait reine Mme Chantal. Aussi, fus-je stupéfait en sentant dans une bouchée de brioche quelque chose de très dur qui faillit me casser une dent. J’ôtai doucement cet objet de ma bouche et j’aperçus une petite poupée de porcelaine, pas plus grosse qu’un haricot. La surprise me fit dire: «Ah!» On me regarda, et Chantal s’écria en battant des mains: «C’est Gaston. C’est Gaston. Vive le roi! vive le roi!» ) PROSE } 
 { NEW-PARA } 
 { R (Tout le monde reprit en chœur: «Vive le roi!» Et je rougis jusqu’aux oreilles, comme on rougit souvent, sans raison, dans les situations un peu sottes. Je demeurais les yeux baissés, tenant entre deux doigts ce grain de faïence, m’efforçant de rire et ne sachant que faire ni que dire, lorsque Chantal reprit: «Maintenant, il faut choisir une reine.» ) PROSE } 
 { NEW-PARA } 
 { R (Alors je fus atterré. En une seconde, mille pensées, mille suppositions me traversèrent l’esprit. Voulait-on me faire désigner une des demoiselles Chantal? Était-ce là un moyen de me faire dire celle que je préférais? Était-ce une douce, légère, insensible poussée des parents vers un mariage possible? L’idée de mariage rôde sans cesse dans toutes les maisons à grandes filles et prend toutes les formes, tous les déguisements, tous les moyens. Une peur atroce de me compromettre m’envahit, et aussi une extrême timidité, devant l’attitude si obstinément correcte et fermée de Mlles Louise et Pauline. Élire l’une d’elles au détriment de l’autre, me sembla aussi difficile que de choisir entre deux gouttes d’eau; et puis, la crainte de m’aventurer dans une histoire où je serais conduit au mariage malgré moi, tout doucement, par des procédés aussi discrets, aussi inaperçus et aussi calmes que cette royauté insignifiante, me troublait horriblement. ) PROSE } 
 { NEW-PARA } 
 { R (Mais tout à coup, j’eus une inspiration, et je tendis à Mlle Perle la poupée symbolique. Tout le monde fut d’abord surpris, puis on apprécia sans doute ma délicatesse et ma discrétion, car on applaudit avec furie. On criait: «Vive la reine! vive la reine!» ) PROSE } 
 { NEW-PARA } 
 { R (Quant à elle, la pauvre vieille fille, elle avait perdu toute contenance; elle tremblait, effarée, et balbutiait: «Mais non… mais non… mais non… pas moi… je vous en prie… pas moi… je vous en prie…» ) PROSE } 
 { NEW-PARA } 
 { R (Alors, pour la première fois de ma vie, je regardai Mlle Perle, et je me demandai ce qu’elle était. ) PROSE } 
 { NEW-PARA } 
 { R (J’étais habitué à la voir dans cette maison, comme on voit les vieux fauteuils de tapisserie sur lesquels on s’assied depuis son enfance sans y avoir jamais pris garde. Un jour, on ne sait pourquoi, parce qu’un rayon de soleil tombe sur le siège, on se dit tout à coup: «Tiens, mais il est fort curieux, ce meuble»; et on découvre que le bois a été travaillé par un artiste, et que l’étoffe est remarquable. Jamais je n’avais pris garde à Mlle Perle. ) PROSE } 
 { NEW-PARA } 
 { R (Elle faisait partie de la famille Chantal, voilà tout; mais comment? À quel titre? — C’était une grande personne maigre qui s’efforçait de rester inaperçue, mais qui n’était pas insignifiante. On la traitait amicalement, mieux qu’une femme de charge, moins bien qu’une parente. Je saisissais tout à coup, maintenant, une quantité de nuances dont je ne m’étais point soucié jusqu’ici! Mme Chantal disait: «Perle.» Les jeunes filles: «Mlle Perle», et Chantal ne l’appelait que mademoiselle, d’un air plus révérend peut-être. ) PROSE } 
 { NEW-PARA } 
 { R (Je me mis à la regarder. — Quel âge avait-elle? Quarante ans? Oui, quarante ans. — Elle n’était pas vieille, cette fille, elle se vieillissait. Je fus soudain frappé par cette remarque. Elle se coiffait, s’habillait, se parait ridiculement, et, malgré tout, elle n’était point ridicule, tant elle portait en elle de grâce simple, naturelle, de grâce voilée, cachée avec soin. Quelle drôle de créature, vraiment! Comment ne l’avais-je jamais mieux observée? Elle se coiffait d’une façon grotesque, avec de petits frisons vieillots tout à fait farces; et, sous cette chevelure à la Vierge conservée, on voyait un grand front calme, coupé par deux rides profondes, deux rides de longues tristesses, puis deux yeux bleus, larges et doux, si timides, si craintifs, si humbles, deux beaux yeux restés si naïfs, pleins d’étonnement de fillette, de sensations jeunes et aussi de chagrins qui avaient passé dedans, en les attendrissant, sans les troubler. ) PROSE } 
 { NEW-PARA } 
 { R (Tout le visage était fin et discret, un de ces visages qui se sont éteints sans avoir été usés, ou fanés par les fatigues ou les grandes émotions de la vie. ) PROSE } 
 { NEW-PARA } 
 { R (Quelle jolie bouche! et quelles jolies dents! Mais on eût dit qu’elle n’osait pas sourire! ) PROSE } 
 { NEW-PARA } 
 { R (Et, brusquement, je la comparai à Mme Chantal! Certes, Mlle Perle était mieux, cent fois mieux, plus fine, plus noble, plus fière. ) PROSE } 
 { NEW-PARA } 
 { R (J’étais stupéfait de mes observations. On versait du champagne. Je tendis mon verre à la reine, en portant sa santé avec un compliment bien tourné. Elle eut envie, je m’en aperçus, de se cacher la figure dans sa serviette; puis, comme elle trempait ses lèvres dans le vin clair, tout le monde cria: «La reine boit! la reine boit!» Elle devint alors toute rouge et s’étrangla. On riait, mais je vis bien qu’on l’aimait beaucoup dans la maison. ) PROSE } 
 { NEW-PARA } 
 { NEW-PARA } 
 { (III) SECTION } 
 { NEW-PARA } 
 { R (Dès que le dîner fut fini, Chantal me prit par le bras. C’était l’heure de son cigare, heure sacrée. Quand il était seul, il allait le fumer dans la rue; quand il avait quelqu’un à dîner, on montait au billard, et il jouait en fumant. Ce soir-là, on avait même fait du feu dans le billard, à cause des Rois; et mon vieil ami prit sa queue, une queue très fine qu’il frotta de blanc avec grand soin, puis il dit: ) PROSE } 
 { NEW-PARA } 
 { R (— À toi, mon garçon! ) PROSE } 
 { NEW-PARA } 
 { R (Car il me tutoyait, bien que j’eusse vingt-cinq ans, mais il m’avait vu tout enfant. ) PROSE } 
 { NEW-PARA } 
 { R (Je commençai donc la partie; je fis quelques carambolages; j’en manquai quelques autres; mais comme la pensée de Mlle Perle me rôdait dans la tête, je demandai tout à coup: ) PROSE } 
 { NEW-PARA } 
 { R (— Dites donc, monsieur Chantal, est-ce que Mlle Perle est votre parente? ) PROSE } 
 { NEW-PARA } 
 { R (Il cessa de jouer, très étonné, et me regarda. ) PROSE } 
 { NEW-PARA } 
 { R (— Comment, tu ne sais pas? tu ne connais pas l’histoire de Mlle Perle? ) PROSE } 
 { NEW-PARA } 
 { R (— Mais non. ) PROSE } 
 { NEW-PARA } 
 { R (— Ton père ne te l’a jamais racontée? ) PROSE } 
 { NEW-PARA } 
 { R (— Mais non. ) PROSE } 
 { NEW-PARA } 
 { R (— Tiens, tiens, que c’est drôle! ah! par exemple, que c’est drôle! Oh! mais, c’est toute une aventure!» ) PROSE } 
 { NEW-PARA } 
 { R (Il se tut, puis reprit: ) PROSE } 
 { NEW-PARA } 
 { R (— Et si tu savais comme c’est singulier que tu me demandes ça aujourd’hui, un jour des Rois! ) PROSE } 
 { NEW-PARA } 
 { R (— Pourquoi? ) PROSE } 
 { NEW-PARA } 
 { R (Ah! pourquoi! Écoute. Voilà de cela quarante et un ans, quarante et un ans aujourd’hui même, jour de l’Épiphanie. Nous habitions alors Roüy-le-Tors, sur les remparts; mais il faut d’abord t’expliquer la maison pour que tu comprennes bien. Roüy est bâti sur une côte, ou plutôt sur un mamelon qui domine un grand pays de prairies. Nous avions là une maison avec un beau jardin suspendu, soutenu en l’air par les vieux murs de défense. Donc la maison était dans la ville, dans la rue, tandis que le jardin dominait la plaine. Il y avait aussi une porte de sortie de ce jardin sur la campagne, au bout d’un escalier secret qui descendait dans l’épaisseur des murs, comme on en  trouve dans les romans. Une route passait devant cette porte qui était munie d’une grosse cloche, car les paysans, pour éviter le grand tour, apportaient par là leurs provisions. ) PROSE } 
 { NEW-PARA } 
 { R (Tu vois bien les lieux, n’est-ce pas? Or, cette année-là, aux Rois, il neigeait depuis une semaine. On eût dit la fin du monde. Quand nous allions aux remparts regarder la plaine, ça nous faisait froid dans l’âme, cet immense pays blanc, tout blanc, glacé, et qui luisait comme du vernis. On eût dit que le bon Dieu avait empaqueté la terre pour l’envoyer au grenier des vieux mondes. Je t’assure que c’était bien triste. ) PROSE } 
 { NEW-PARA } 
 { R (Nous demeurions en famille à ce moment-là, et nombreux, très nombreux:  mon père, ma mère, mon oncle et ma tante, mes deux frères et mes quatre cousines; c’étaient de jolies fillettes; j’ai épousé la dernière. De tout ce monde-là, nous ne sommes plus que trois survivants: ma femme, moi et ma belle-sœur qui habite Marseille. Sacristi, comme ça s’égrène, une famille! ça me fait trembler quand j’y pense! Moi, j’avais quinze ans, puisque j’en ai cinquante-six. ) PROSE } 
 { NEW-PARA } 
 { R (Donc, nous allions fêter les Rois, et nous étions très gais, très gais! Tout le monde attendait le dîner dans le salon, quand mon frère aîné, Jacques, se mit à dire: «Il y a un chien qui hurle dans la plaine depuis dix minutes, ça doit être une pauvre bête perdue.» ) PROSE } 
 { NEW-PARA } 
 { R (Il n’avait pas fini de parler, que la cloche du jardin tinta. Elle avait un gros son de cloche d’église qui faisait penser aux morts. Tout le monde en frissonna. Mon père appela le domestique et lui dit d’aller voir. On attendit en grand silence; nous pensions à la neige qui couvrait toute la terre. Quand l’homme revint, il affirma qu’il n’avait rien vu. Le chien hurlait toujours, sans cesse, et sa voix ne changeait point de place. ) PROSE } 
 { NEW-PARA } 
 { R (On se mit à table; mais nous étions un peu émus, surtout les jeunes. Ça alla bien jusqu’au rôti, puis voilà que la cloche se remet à sonner, trois fois de suite, trois grands coups, longs, qui ont vibré jusqu’au bout de nos doigts et qui nous ont coupé le souffle, tout net. Nous restions à nous regarder, la fourchette en l’air, écoutant toujours, et saisis d’une espèce de peur surnaturelle. ) PROSE } 
 { NEW-PARA } 
 { R (Ma mère enfin parla: «C’est étonnant qu’on ait attendu si longtemps pour revenir; n’allez pas seul, Baptiste; un de ces messieurs va vous accompagner.» ) PROSE } 
 { NEW-PARA } 
 { R (Mon oncle François se leva. C’était une espèce d’hercule, très fier de sa force et qui ne craignait rien au monde. Mon père lui dit: «Prends un fusil. On ne sait pas ce que ça peut être.» ) PROSE } 
 { NEW-PARA } 
 { R (Mais mon oncle ne prit qu’une canne et sortit aussitôt avec le domestique. ) PROSE } 
 { NEW-PARA } 
 { R (Nous autres, nous demeurâmes frémissants de terreur et d’angoisse, sans manger, sans parler. Mon père essaya de nous rassurer: «Vous allez voir, dit-il, que ce sera quelque mendiant ou quelque passant perdu dans la neige. Après avoir sonné une première fois, voyant qu’on n’ouvrait pas tout de suite, il a tenté de retrouver son chemin, puis, n’ayant pu y parvenir, il est revenu à notre porte.» ) PROSE } 
 { NEW-PARA } 
 { R (L’absence de mon oncle nous parut durer une heure. Il revint enfin, furieux, jurant: «Rien, nom de nom, c’est un farceur! Rien que ce maudit chien qui hurle à cent mètres des murs. Si j’avais pris un fusil, je l’aurais tué pour le faire taire.» ) PROSE } 
 { NEW-PARA } 
 { R (On se remit à dîner, mais tout le monde demeurait anxieux; on sentait bien que ce n’était pas fini, qu’il allait se passer quelque chose, que la cloche, tout à l’heure, sonnerait encore. ) PROSE } 
 { NEW-PARA } 
 { R (Et elle sonna, juste au moment où l’on coupait le gâteau des Rois. Tous les hommes se levèrent ensemble. Mon oncle François, qui avait bu du champagne, affirma qu’il allait LE massacrer, avec tant de fureur, que ma mère et ma tante se jetèrent sur lui pour l’empêcher. Mon père, bien que très calme et un peu impotent (il traînait la jambe depuis qu’il se l’était cassée en tombant de cheval), déclara à son tour qu’il voulait savoir ce que c’était, et qu’il irait. Mes frères, âgés de dix-huit et de vingt ans, coururent chercher leurs fusils; et comme on ne faisait guère attention à moi, je m’emparai d’une carabine de jardin et je me disposai aussi à accompagner l’expédition. ) PROSE } 
 { NEW-PARA } 
 { R (Elle partit aussitôt. Mon père et mon oncle marchaient devant, avec Baptiste, qui portait une lanterne. Mes frères Jacques et Paul suivaient, et je venais derrière, malgré les supplications de ma mère, qui demeurait avec sa sœur et mes cousines sur le seuil de la maison. ) PROSE } 
 { NEW-PARA } 
 { R (La neige s’était remise à tomber depuis une heure; et les arbres en étaient chargés. Les sapins pliaient sous ce lourd vêtement livide, pareils à des pyramides blanches, à d’énormes pains de sucre; et on apercevait à peine, à travers le rideau gris des flocons menus et pressés, les arbustes plus légers, tout pâles dans l’ombre. Elle tombait si épaisse, la neige, qu’on y voyait tout juste à dix pas. Mais la lanterne jetait une grande clarté devant nous. Quand on commença à descendre par l’escalier tournant creusé dans la muraille, j’eus peur, vraiment. Il me sembla qu’on marchait derrière moi; qu’on allait me saisir par les épaules et m’emporter; et j’eus envie de retourner; mais comme il fallait retraverser tout le jardin, je n’osai pas. ) PROSE } 
 { NEW-PARA } 
 { R (J’entendis qu’on ouvrait la porte sur la plaine; puis mon oncle se remit à jurer: «Nom d’un nom, il est reparti! Si j’aperçois seulement son ombre, je ne le rate pas, ce c…-là.» ) PROSE } 
 { NEW-PARA } 
 { R (C’était sinistre de voir la plaine, ou, plutôt, de la sentir devant soi, car on ne la voyait pas; on ne voyait qu’un voile de neige sans fin, en haut, en bas, en face, à droite, à gauche, partout. ) PROSE } 
 { NEW-PARA } 
 { R (Mon oncle reprit: «Tiens, revoilà le chien qui hurle; je vais lui apprendre comment je tire, moi. Ça sera toujours ça de gagné.» ) PROSE } 
 { NEW-PARA } 
 { R (Mais mon père, qui était bon, reprit: «Il vaut mieux l’aller chercher, ce pauvre animal qui crie la faim. Il aboie au secours, ce misérable; il appelle comme un homme en détresse. Allons-y.» ) PROSE } 
 { NEW-PARA } 
 { R (Et on se mit en route à travers ce rideau, à travers cette tombée épaisse, continue, à travers cette mousse qui emplissait la nuit et l’air, qui remuait, flottait, tombait et glaçait la chair en fondant, la glaçait comme elle l’aurait brûlée, par une douleur vive et rapide sur la peau, à chaque toucher des petits flocons blancs. ) PROSE } 
 { NEW-PARA } 
 { R (Nous enfoncions jusqu’aux genoux dans cette pâte molle et froide; et il fallait lever très haut la jambe pour marcher. À mesure que nous avancions, la voix du chien devenait plus claire, plus forte. Mon oncle cria: «Le voici!» On s’arrêta pour l’observer, comme on doit faire en face d’un ennemi qu’on rencontre dans la nuit. ) PROSE } 
 { NEW-PARA } 
 { R (Je ne voyais rien, moi; alors, je rejoignis les autres, et je l’aperçus; il était effrayant et fantastique à voir, ce chien, un gros chien noir, un chien de berger à grands poils et à tête de loup, dressé sur ses quatre pattes, tout au bout de la longue traînée de lumière que faisait la lanterne sur la neige. Il ne bougeait pas; il s’était tu; et il nous regardait. ) PROSE } 
 { NEW-PARA } 
 { R (Mon oncle dit: «C’est singulier, il n’avance ni ne recule. J’ai bien envie de lui flanquer un coup de fusil.» ) PROSE } 
 { NEW-PARA } 
 { R (Mon père reprit d’une voix ferme: «Non, il faut le prendre.» ) PROSE } 
 { NEW-PARA } 
 { R (Alors mon frère Jacques ajouta: «Mais il n’est pas seul. Il y a quelque chose à côté de lui.» ) PROSE } 
 { NEW-PARA } 
 { R (Il y avait quelque chose derrière lui, en effet, quelque chose de gris, d’impossible à distinguer. On se remit en marche avec précaution. ) PROSE } 
 { NEW-PARA } 
 { R (En nous voyant approcher, le chien s’assit sur son derrière. Il n’avait pas l’air méchant. Il semblait plutôt content d’avoir réussi à attirer des gens. ) PROSE } 
 { NEW-PARA } 
 { R (Mon père alla droit à lui et le caressa. Le chien lui lécha les mains ; et on reconnut qu’il était attaché à la roue d’une petite voiture, d’une sorte de voiture joujou enveloppée tout entière dans trois ou quatre couvertures de laine. On enleva ces linges avec soin, et comme  Baptiste approchait sa lanterne de la porte de cette carriole qui ressemblait à une niche roulante, on aperçut dedans un petit enfant qui dormait. ) PROSE } 
 { NEW-PARA } 
 { R (Nous fûmes tellement stupéfaits que nous ne pouvions dire un mot. Mon père se remit le premier, et comme il était de grand cœur, et d’âme un peu exaltée, il étendit la main sur le toit de la voiture et il dit: «Pauvre abandonné, tu seras des nôtres!» Et il ordonna à mon frère Jacques de rouler devant nous notre trouvaille. ) PROSE } 
 { NEW-PARA } 
 { R (Mon père reprit, pensant tout haut:  ) PROSE } 
 { NEW-PARA } 
 { R («Quelque enfant d’amour dont la pauvre mère est venue sonner à ma porte en cette nuit de l’Épiphanie, en souvenir de l’Enfant-Dieu.» ) PROSE } 
 { NEW-PARA } 
 { R (Il s’arrêta de nouveau, et, de toute sa force, il cria quatre fois à travers la nuit vers les quatre coins du ciel: «Nous l’avons recueilli!» Puis, posant la main sur l’épaule de son frère, il murmura: «Si tu avais tiré sur le chien, François?…» ) PROSE } 
 { NEW-PARA } 
 { R (Mon oncle ne répondit pas, mais il fit, dans l’ombre, un grand signe de croix, car il était très religieux, malgré ses airs fanfarons. ) PROSE } 
 { NEW-PARA } 
 { R (On avait détaché le chien, qui nous suivait. ) PROSE } 
 { NEW-PARA } 
 { R (Ah! par exemple, ce qui fut gentil à voir, c’est la rentrée à la maison. On eut d’abord beaucoup de mal à monter la voiture par l’escalier des remparts; on y parvint cependant et on la roula jusque dans le vestibule. ) PROSE } 
 { NEW-PARA } 
 { R (Comme maman était drôle, contente et effarée! Et mes quatre petites cousines (la plus jeune avait six ans), elles ressemblaient à quatre poules autour d’un nid. On retira enfin de sa voiture l’enfant qui dormait toujours. C’était une fille, âgée de six semaines environ. Et on trouva dans ses langes dix mille francs en or, oui, dix mille francs! que papa plaça pour lui faire une dot. Ce n’était donc pas une enfant de pauvres… mais peut-être l’enfant de quelque noble avec une petite bourgeoise de la ville… ou encore… nous avons fait mille suppositions et on n’a jamais rien su… mais là, jamais rien… jamais rien… Le chien lui-même ne fut reconnu par personne. Il était étranger au pays. Dans tous les cas, celui ou celle qui était venu sonner trois fois à notre porte connaissait bien mes parents, pour les avoir choisis ainsi. ) PROSE } 
 { NEW-PARA } 
 { R (Voilà donc comment Mlle Perle entra, à l’âge de six semaines, dans la maison Chantal. ) PROSE } 
 { NEW-PARA } 
 { R (On ne la nomma que plus tard, Mlle Perle, d’ailleurs. On la fit baptiser d’abord: «Marie, Simonne, Claire», Claire devant lui servir de nom de famille. ) PROSE } 
 { NEW-PARA } 
 { R (Je vous assure que ce fut une drôle de rentrée dans la salle à manger avec cette mioche réveillée qui regardait autour d’elle ces gens et ces lumières, de ses yeux vagues, bleus et troubles. ) PROSE } 
 { NEW-PARA } 
 { R (On se remit à table et le gâteau fut partagé. J’étais roi; et je pris pour reine Mlle Perle, comme vous, tout à l’heure. Elle ne se douta guère, ce jour-là, de l’honneur qu’on lui faisait. ) PROSE } 
 { NEW-PARA } 
 { R (Donc l’enfant fut adoptée, et élevée dans la famille. Elle grandit; des années passèrent. Elle était gentille, douce, obéissante. Tout le monde l’aimait et on l’aurait abominablement gâtée si ma mère ne l’eût empêché. ) PROSE } 
 { NEW-PARA } 
 { R (Ma mère était une femme d’ordre et de hiérarchie. Elle consentait à traiter la petite Claire comme ses propres fils, mais elle tenait cependant à ce que la distance qui nous séparait fût bien marquée, et la situation bien établie. ) PROSE } 
 { NEW-PARA } 
 { R (Aussi, dès que l’enfant put comprendre, elle lui fit connaître son histoire et fit pénétrer tout doucement, même tendrement dans l’esprit de la petite, qu’elle était pour les Chantal une fille adoptive, recueillie, mais en somme une étrangère. ) PROSE } 
 { NEW-PARA } 
 { R (Claire comprit cette situation avec une singulière intelligence, avec un instinct surprenant; et elle sut prendre et garder la place qui lui était laissée, avec tant de tact, de grâce et de gentillesse, qu’elle touchait mon père à le faire pleurer. ) PROSE } 
 { NEW-PARA } 
 { R (Ma mère elle-même fut tellement émue par la reconnaissance passionnée et le dévouement un peu craintif de cette mignonne et tendre créature, qu’elle se mit à l’appeler: «Ma fille.» Parfois quand la petite avait fait quelque chose de bon, de délicat, ma mère relevait ses lunettes sur son front, ce qui indiquait toujours une émotion chez elle et elle répétait: «Mais c’est une perle, une vraie perle, cette enfant!» — Ce nom en resta à la petite Claire qui devint et demeura pour nous Mlle Perle. ) PROSE } 
 { NEW-PARA } 
 { NEW-PARA } 
 { (IV) SECTION } 
 { NEW-PARA } 
 { R (M. Chantal se tut. Il était assis sur le billard, les pieds ballants, et il maniait une boule de la main gauche, tandis que de la droite il tripotait un linge qui servait à effacer les points sur le tableau d’ardoise et que nous appelions le «linge à craie». Un peu rouge, la voix sourde, il parlait pour lui maintenant, parti dans ses souvenirs, allant doucement, à travers les choses anciennes et les vieux événements qui se réveillaient dans sa pensée, comme on va, en se promenant, dans les vieux jardins de famille où l’on fut élevé, et où chaque arbre, chaque chemin, chaque plante, les houx pointus, les lauriers qui sentent bon, les ifs dont la graine rouge et grasse s’écrase entre les doigts, font surgir, à chaque pas, un petit fait de notre vie passée, un de ces petits faits insignifiants et délicieux qui forment le fond même, la trame de l’existence. ) PROSE } 
 { NEW-PARA } 
 { R (Moi, je restais en face de lui, adossé à la muraille, les mains appuyées sur ma queue de billard inutile. ) PROSE } 
 { NEW-PARA } 
 { R (Il reprit, au bout d’une minute: «Cristi, qu’elle était jolie à dix-huit ans… et gracieuse… et parfaite… Ah! la jolie… jolie… jolie… et bonne… et brave… et charmante fille!… Elle avait des yeux… des yeux bleus… transparents… clairs… comme je n’en ai jamais vu de pareils… jamais!» ) PROSE } 
 { NEW-PARA } 
 { R (Il se tut encore. Je demandai: «Pourquoi ne s’est-elle pas mariée?» ) PROSE } 
 { NEW-PARA } 
 { R (Il répondit, non pas à moi, mais à ce mot qui passait «mariée». ) PROSE } 
 { NEW-PARA } 
 { R (— Pourquoi? pourquoi? Elle n’a pas voulu… pas voulu. Elle avait pourtant trente mille francs de dot, et elle fut demandée plusieurs fois… elle n’a pas voulu! Elle semblait triste à cette époque-là. C’est quand j’épousai ma cousine, la petite Charlotte, ma femme, avec qui j’étais fiancé depuis six ans.» ) PROSE } 
 { NEW-PARA } 
 { R (Je regardais M. Chantal et il me semblait que je pénétrais dans son esprit, que je pénétrais tout à coup dans un de ces humbles et cruels drames des cœurs honnêtes, des cœurs droits, des cœurs sans reproches, dans un de ces cœurs inavoués, inexplorés, que personne n’a connu, pas même ceux qui en sont les muettes et résignées victimes. ) PROSE } 
 { NEW-PARA } 
 { R (Et, une curiosité hardie me poussant tout à coup, je prononçai: ) PROSE } 
 { NEW-PARA } 
 { R (— C’est vous qui auriez dû l’épouser, monsieur Chantal? ) PROSE } 
 { NEW-PARA } 
 { R (Il tressaillit, me regarda, et dit: ) PROSE } 
 { NEW-PARA } 
 { R (— Moi? épouser qui? ) PROSE } 
 { NEW-PARA } 
 { R (— Mlle Perle. ) PROSE } 
 { NEW-PARA } 
 { R (— Pourquoi ça? ) PROSE } 
 { NEW-PARA } 
 { R (— Parce que vous l’aimiez plus que votre cousine. ) PROSE } 
 { NEW-PARA } 
 { R (Il me regarda avec des yeux étranges, ronds, effarés, puis il balbutia: ) PROSE } 
 { NEW-PARA } 
 { R (— Je l’ai aimée… moi?… comment? qu’est-ce qui t’a dit ça?… ) PROSE } 
 { NEW-PARA } 
 { R (— Parbleu, ça se voit… et c’est même à cause d’elle que vous avez tardé si longtemps à épouser votre cousine qui vous attendait depuis six ans. ) PROSE } 
 { NEW-PARA } 
 { R (Il lâcha la bille qu’il tenait de la main gauche, saisit à deux mains le linge à craie, et, s’en couvrant le visage, se mit à sangloter dedans. Il pleurait d’une façon désolante et ridicule, comme pleure une éponge qu’on presse, par les yeux, le nez et la bouche en même temps. Et il toussait, crachait, se mouchait dans le linge à craie, s’essuyait les yeux, éternuait, recommençait à couler par toutes les fentes de son visage, avec un bruit de gorge qui faisait penser aux gargarismes. ) PROSE } 
 { NEW-PARA } 
 { R (Moi, effaré, honteux, j’avais envie de me sauver et je ne savais plus que dire, que faire, que tenter. ) PROSE } 
 { NEW-PARA } 
 { R (Et soudain, la voix de Mme Chantal résonna dans l’escalier: «Est-ce bientôt fini, votre fumerie?» ) PROSE } 
 { NEW-PARA } 
 { R (J’ouvris la porte et je criai: «Oui, madame, nous descendons.» ) PROSE } 
 { NEW-PARA } 
 { R (Puis, je me précipitai vers son mari, et, le saisissant par les coudes: «Monsieur Chantal, mon ami Chantal, écoutez-moi; votre femme vous appelle, remettez-vous, remettez-vous vite, il faut descendre; remettez-vous.» ) PROSE } 
 { NEW-PARA } 
 { R (Il bégaya: «Oui… oui… je viens… pauvre fille!… je viens… dites-lui que j’arrive.» ) PROSE } 
 { NEW-PARA } 
 { R (Et il commença à s’essuyer consciencieusement la figure avec le linge qui, depuis deux ou trois ans, essuyait toutes les marques de l’ardoise, puis il apparut, moitié blanc et moitié rouge, le front, le nez, les joues et le menton barbouillés de craie, et les yeux gonflés, encore pleins de larmes. ) PROSE } 
 { NEW-PARA } 
 { R (Je le pris par les mains et l’entraînai dans sa chambre en murmurant: «Je vous demande pardon, je vous demande bien pardon, monsieur Chantal, de vous avoir fait de la peine… mais… je ne savais pas… vous … vous comprenez…» ) PROSE } 
 { NEW-PARA } 
 { R (Il me serra la main: «Oui… oui… il y a des moments difficiles…» ) PROSE } 
 { NEW-PARA } 
 { R (Puis il se plongea la figure dans sa cuvette. Quand il en sortit, il ne me parut pas encore présentable; mais j’eus l’idée d’une petite ruse. Comme il s’inquiétait, en se regardant dans la glace, je lui dis: «Il suffira de raconter que vous avez un grain de poussière dans l’œil, et vous pourrez pleurer devant tout le monde autant qu’il vous plaira.» ) PROSE } 
 { NEW-PARA } 
 { R (Il descendit en effet, en se frottant les yeux avec son mouchoir. On s’inquiéta; chacun voulut chercher le grain de poussière qu’on ne trouva point, et on raconta des cas semblables où il était devenu nécessaire d’aller chercher le médecin. ) PROSE } 
 { NEW-PARA } 
 { R (Moi, j’avais rejoint Mlle Perle et je la regardais, tourmenté par une curiosité ardente, une curiosité qui devenait une souffrance. Elle avait dû être bien jolie en effet, avec ses yeux doux, si grands, si calmes, si larges qu’elle avait l’air de ne les jamais fermer, comme font les autres humains. Sa toilette était un peu ridicule, une vraie toilette de vieille fille, et la déparait sans la rendre gauche. ) PROSE } 
 { NEW-PARA } 
 { R (Il me semblait que je voyais en elle, comme j’avais vu tout à l’heure dans l’âme de M. Chantal, que j’apercevais, d’un bout à l’autre, cette vie humble, simple et dévouée; mais un besoin me venait aux lèvres, un besoin harcelant de l’interroger, de savoir si, elle aussi, l’avait aimé, lui; si elle avait souffert comme lui de cette longue souffrance secrète, aiguë, qu’on ne voit pas, qu’on ne sait pas, qu’on ne devine pas, mais qui s’échappe la nuit, dans la solitude de la chambre noire. Je la regardais, je voyais battre son cœur sous son corsage à guimpe, et je me demandais si cette douce figure candide avait gémi chaque soir, dans l’épaisseur moite de l’oreiller, et sangloté, le corps secoué de sursauts, dans la fièvre du lit brûlant. ) PROSE } 
 { NEW-PARA } 
 { R (Et je lui dis tout bas, comme font les enfants qui cassent un bijou pour voir dedans: «Si vous aviez vu pleurer M. Chantal tout à l’heure, il vous aurait fait pitié.» ) PROSE } 
 { NEW-PARA } 
 { R (Elle tressaillit: «Comment, il pleurait? ) PROSE } 
 { NEW-PARA } 
 { R (— Oh! oui, il pleurait! ) PROSE } 
 { NEW-PARA } 
 { R (— Et pourquoi ça?» ) PROSE } 
 { NEW-PARA } 
 { R (Elle semblait très émue. Je répondis: ) PROSE } 
 { NEW-PARA } 
 { R (— À votre sujet. ) PROSE } 
 { NEW-PARA } 
 { R (— À mon sujet? ) PROSE } 
 { NEW-PARA } 
 { R (— Oui. Il me racontait combien il vous avait aimée autrefois; et combien il lui en avait coûté d’épouser sa femme au lieu de vous…» ) PROSE } 
 { NEW-PARA } 
 { R (Sa figure pâle me parut s’allonger un peu; ses yeux toujours ouverts, ses yeux calmes se fermèrent tout à coup, si vite qu’ils semblaient s’être clos pour toujours. Elle glissa de sa chaise sur le plancher et s’y affaissa doucement, lentement, comme aurait fait une écharpe tombée. ) PROSE } 
 { NEW-PARA } 
 { R (Je criai: «Au secours! au secours! Mlle Perle se trouve mal.» ) PROSE } 
 { NEW-PARA } 
 { R (Mme Chantal et ses filles se précipitèrent, et comme on cherchait de l’eau, une serviette et du vinaigre, je pris mon chapeau et je me sauvai. ) PROSE } 
 { NEW-PARA } 
 { R (Je m’en allai à grands pas, le cœur secoué, l’esprit plein de remords et de regrets. Et parfois aussi j’étais content; il me semblait que j’avais fait une chose louable et nécessaire. ) PROSE } 
 { NEW-PARA } 
 { R (Je me demandais: «Ai-je eu tort? Ai-je eu raison?» Ils avaient cela dans l’âme comme on garde du plomb dans une plaie fermée. Maintenant ne seront-ils pas plus heureux? Il était trop tard pour que recommençât leur torture et assez tôt pour qu’ils s’en souvinssent avec attendrissement. ) PROSE } 
 { NEW-PARA } 
 { R (Et peut-être qu’un soir du prochain printemps, émus par un rayon de lune tombé sur l’herbe à leurs pieds, à travers les branches, ils se prendront et se serreront la main en souvenir de toute cette souffrance étouffée et cruelle; et peut-être aussi que cette courte étreinte fera passer dans leurs veines un peu de ce frisson qu’ils n’auront point connu, et leur jettera, à ces morts ressuscités en une seconde, la rapide et divine sensation de cette ivresse, de cette folie qui donne aux amoureux plus de bonheur en un tressaillement, que n’en peuvent cueillir, en toute leur vie, les autres hommes!) PROSE } 
